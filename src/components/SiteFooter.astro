---
import avabFooterLogo from "../assets/AVAB_logotyp_neg_green-white.png";
---

<footer class="site-footer">
  <div class="avab-container">
    <div class="footer-grid">
      <div>
        <a class="brand" href="/" aria-label="AVAB - till startsidan">
          <img src={avabFooterLogo.src} alt="AVAB" width="154" height="43" />
        </a>
        <p>AV-teknik, ljud, bild, säkerhet och kommunikation för konferensrum, skolor, sporthallar, hotell och publika miljöer - projektering, installation och drift över hela Sverige.</p>
      </div>

      <nav aria-label="Sidlänkar">
        <h2>Genvägar</h2>
        <ul class="footer-links">
          <li><a href="#losningar">Lösningar</a></li>
          <li><a href="#miljoer">Miljöer</a></li>
          <li><a href="#referenser">Referensprojekt</a></li>
          <li><a href="#projektering">Projektering</a></li>
          <li><a href="#faq-kunskap">Kunskapsbank</a></li>
        </ul>
      </nav>

      <div>
        <h2>Kontakt</h2>
        <address class="footer-contact" style="font-style: normal;">
          <a href="tel:+46548202080">054-820 20 80</a>
          <a href="mailto:info@avab.eu">info@avab.eu</a>
          <span>Skraggevägen 4<br>663 41 Hammarö, Värmland</span>
        </address>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© <span id="year">2026</span> AVAB. Alla rättigheter förbehållna.</span>
      <span>Org.nr 556977-1776 · <a href="/integritetspolicy/" class="footer-privacy">Integritetspolicy</a></span>
    </div>
  </div>
</footer>

<script>
  const year = document.getElementById('year');
  if (year) year.textContent = String(new Date().getFullYear());
</script>
