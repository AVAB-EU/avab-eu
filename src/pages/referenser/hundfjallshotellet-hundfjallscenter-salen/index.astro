  <!-- Sidspecifika komponenter -->
  <style>
    /* ---- AEO-svarsruta (referensvariant med etikett) ---- */
    .snippet-box {
      margin-top: 28px;
      padding: 28px 30px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-left: 6px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
    }
    .snippet-box .label { display: block; margin-bottom: 8px; color: var(--avab-green); font-size: 0.78rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; }
    .snippet-box h3 { font-size: 1.25rem; margin-bottom: 10px; }
    .snippet-box p:last-child { margin-bottom: 0; font-size: 1.02rem; }

    /* ---- Berättelsen i tre steg ---- */
    .story-steps {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin-top: 30px;
    }
    .story-step {
      padding: 26px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
      position: relative;
      overflow: hidden;
    }
    .story-step::before { content: ""; position: absolute; inset: 0 auto 0 0; width: 5px; background: var(--avab-green); }
    .story-step b { display: block; margin-bottom: 8px; color: var(--avab-green); font-size: 0.78rem; font-weight: 800; letter-spacing: 0.05em; }
    .story-step h3 { font-size: 1.2rem; margin-bottom: 8px; }
    .story-step p { margin: 0; color: var(--avab-dark-muted); font-size: 0.95rem; }

    /* ---- Citatrader ---- */
    .quote-line {
      margin: 30px 0 0;
      padding: 24px 30px;
      border-left: 6px solid var(--avab-green);
      background: var(--avab-white);
      border-top: 1px solid var(--avab-border);
      border-right: 1px solid var(--avab-border);
      border-bottom: 1px solid var(--avab-border);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
      font-weight: 700;
      font-size: 1.15rem;
      color: var(--avab-dark);
      font-style: italic;
    }

    /* ---- Nyckeltal ---- */
    .metrics {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-top: 8px;
    }
    .metric {
      padding: 28px 22px;
      border: 1px solid var(--avab-border);
      border-top: 4px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-white);
      box-shadow: var(--avab-shadow-sm);
    }
    .metric strong { display: block; margin-bottom: 8px; color: var(--avab-dark); font-size: 1.4rem; line-height: 1.1; }
    .metric span { color: var(--avab-dark-muted); font-size: 0.92rem; }

    /* ---- Tagglista (bottenplanets ytor) ---- */
    .tag-list { display: flex; flex-wrap: wrap; gap: 8px; margin: 20px 0 0; padding: 0; list-style: none; }
    .tag-list li {
      padding: 7px 14px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-radius: 999px;
      font-size: 0.86rem;
      font-weight: 600;
      color: var(--avab-dark-muted);
    }

    /* ---- Musikens dygn (tidsflöde) ---- */
    .timeflow {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin-top: 34px;
    }
    .timeflow article {
      padding: 26px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
    }
    .timeflow time { display: block; margin-bottom: 8px; color: var(--avab-green); font-size: 0.82rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; }
    .timeflow h3 { font-size: 1.15rem; margin-bottom: 8px; }
    .timeflow p { margin: 0; color: var(--avab-dark-muted); font-size: 0.94rem; }

    /* ---- Konferensrumskort ---- */
    .room-2col { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; margin-top: 30px; }
    .room-card {
      padding: 30px 32px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
    }
    .room-card h3 { font-size: 1.25rem; margin-bottom: 14px; }
    .room-card ul { margin: 0; padding-left: 20px; }
    .room-card li { color: var(--avab-dark-muted); font-size: 0.96rem; margin-bottom: 8px; }

    /* ---- Dante-signalflöde ---- */
    .signal-flow {
      display: grid;
      grid-template-columns: 1fr auto 1fr auto 1fr;
      gap: 16px;
      align-items: center;
      margin-top: 28px;
    }
    .signal-node {
      min-height: 104px;
      display: grid;
      place-items: center;
      padding: 18px;
      border: 1px solid var(--avab-border);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-white);
      box-shadow: var(--avab-shadow-sm);
      text-align: center;
      font-weight: 700;
    }
    .signal-arrow { color: var(--avab-green); font-size: 1.8rem; font-weight: 800; text-align: center; }

    /* ---- Galleri + bildramar ---- */
    .gallery {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 18px;
      margin-top: 34px;
    }
    .span-7 { grid-column: span 7; }
    .span-6 { grid-column: span 6; }
    .span-5 { grid-column: span 5; }
    .image-frame {
      overflow: hidden;
      border-radius: var(--avab-radius-sm);
      background: var(--avab-grey);
      border: 1px solid var(--avab-border);
    }
    .image-frame img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }
    .image-frame.tall img { aspect-ratio: 4 / 5; }
    .image-frame.contain { background: var(--avab-white); }
    .image-frame.contain img { object-fit: contain; }
    .gallery figure, .two-col figure { margin: 0; }
    figcaption { padding-top: 12px; color: var(--avab-dark-muted); font-size: 0.88rem; }

    /* Placeholder tills äkta projektbild läggs in */
    .image-placeholder {
      min-height: 300px;
      height: 100%;
      display: grid;
      place-items: center;
      padding: 28px;
      border: 2px dashed rgba(40, 46, 42, 0.28);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-grey);
      color: var(--avab-dark-muted);
      text-align: center;
    }
    .image-placeholder strong { display: block; margin-bottom: 8px; color: var(--avab-dark); }

    /* ---- FAQ: vänsterställd rubrik + tvåkolumnslayout ---- */
    .faq-heading { max-width: 760px; margin: 0 0 30px; text-align: left; }
    .faq-heading .eyebrow { margin-left: 0; margin-right: 0; }
    .faq-heading h2 { margin-bottom: 12px; max-width: 680px; }
    .faq-heading p { color: var(--avab-dark-muted); margin-bottom: 0; max-width: 760px; }

    .compact-faq {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 28px;
      row-gap: 0;
      max-width: 1060px;
      margin: 0 auto;
    }
    .compact-faq details.faq-item { padding: 20px 0; }
    .compact-faq summary { font-size: 1.05rem; }
    .compact-faq details.faq-item p { font-size: 0.98rem; }
    .compact-faq details.faq-item:nth-child(1),
    .compact-faq details.faq-item:nth-child(2) { border-top: 1px solid var(--avab-border); }

    .hundfjall-faq-cta {
      padding-top: 48px;
      padding-bottom: 96px;
    }
    .hundfjall-faq-cta .compact-faq {
      margin-bottom: 64px;
    }

    /* ---- Responsivt (sidspecifikt) ---- */
    @media (max-width: 1024px) {
      .story-steps, .timeflow { grid-template-columns: 1fr; }
      .metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .room-2col { grid-template-columns: 1fr; }
      .signal-flow { grid-template-columns: 1fr; }
      .signal-arrow { transform: rotate(90deg); }
    }
    @media (max-width: 768px) {
      .metrics { grid-template-columns: 1fr; }
      .span-7, .span-6, .span-5 { grid-column: span 12; }
      .compact-faq { grid-template-columns: 1fr; }
      .compact-faq details.faq-item:nth-child(2) { border-top: none; }
      .hundfjall-faq-cta {
        padding-top: 40px;
        padding-bottom: 72px;
      }
      .hundfjall-faq-cta .compact-faq {
        margin-bottom: 44px;
      }
    }
  </style>
</head>
