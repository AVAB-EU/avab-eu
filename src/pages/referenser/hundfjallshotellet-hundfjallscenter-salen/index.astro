  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": "https://www.avab.eu/referenser/hundfjallshotellet-hundfjallscenter-salen/#faq",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad levererade AVAB till Hundfjällshotellet och Hundfjällscenter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AVAB projekterade ljudspridningen och installerade 494 högtalare i 28 appstyrda ljudzoner samt Dante, konferensteknik, trådlösa mikrofoner och SLS-hörslinga."
        }
      },
      {
        "@type": "Question",
        "name": "Varför installerades så många högtalare?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Många noggrant placerade högtalare skapar en jämn ljudmatta utan starka punkter och volymdippar. Varje högtalare kan då arbeta på lägre nivå."
        }
      },
      {
        "@type": "Question",
        "name": "Hur styrs de 28 ljudzonerna?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Varje zon kan styras separat från app. Spellista, tempo och volym kan följa ett tidsschema och anpassas efter verksamheten under dagen."
        }
      },
      {
        "@type": "Question",
        "name": "Hur fungerar konferensrummen med vikväggar?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "De fyra mindre rummen fungerar separat när vikväggarna är stängda. När en vägg öppnas slås ljudet ihop och presentationens ljud spelas i alla åtta högtalare i det större rummet."
        }
      },
      {
        "@type": "Question",
        "name": "Hur kopplas Hundfjällscenter och hotellet ihop?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ett Dante-system transporterar digitalt ljud mellan husen över nätverket. En trubadur vid Mondo kan därför skickas vidare till valda ljudzoner i hotellet."
        }
      },
      {
        "@type": "Question",
        "name": "Finns hörslinga i konferensanläggningen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Det stora konferensrummet är utrustat med en SLS-hörslinga. De fyra mindre konferensrummen har ingen hörslinga."
        }
      }
    ]
  }
  </script>

