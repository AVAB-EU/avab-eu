    imagesizes="100vw">

  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Sidspecifika komponenter -->
  <style>
    /* ---- AEO-svarsruta (referensvariant med etikett) ---- */
    .snippet-box {
      margin-top: 28px;
      padding: 28px 30px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-left: 6px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
    }
    .snippet-box .label { display: block; margin-bottom: 8px; color: var(--avab-green); font-size: 0.78rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; }
    .snippet-box h3 { font-size: 1.3rem; margin-bottom: 10px; }
    .snippet-box p:last-child { margin-bottom: 0; }

    /* ---- Zonlista ---- */
    .zone-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin-top: 28px;
    }
    .zone {
      padding: 22px 24px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-left: 4px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
    }
    .zone b { display: block; margin-bottom: 4px; color: var(--avab-dark); font-size: 1.02rem; }
    .zone span { color: var(--avab-dark-muted); font-size: 0.93rem; line-height: 1.5; }

    /* ---- Tidsbesparingstabell ---- */
    .time-table-wrap { margin-top: 30px; overflow-x: auto; border: 1px solid var(--avab-border); border-radius: var(--avab-radius-sm); box-shadow: var(--avab-shadow-sm); background: var(--avab-white); }
    .time-table { width: 100%; border-collapse: collapse; font-size: 0.98rem; }
    .time-table th {
      text-align: left;
      padding: 15px 22px;
      background: var(--avab-dark);
      color: #fff;
      font-size: 0.78rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .time-table td { padding: 15px 22px; border-top: 1px solid var(--avab-border); color: var(--avab-dark-muted); }
    .time-table td:first-child { font-weight: 700; color: var(--avab-dark); }
    .time-table tr.highlight td { background: rgba(143, 192, 37, 0.08); color: var(--avab-dark); font-weight: 700; }

    /* ---- Nyckeltal ---- */
    .metrics {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-top: 34px;
    }
    .metric {
      padding: 28px 22px;
      border: 1px solid var(--avab-border);
      border-top: 4px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-white);
      box-shadow: var(--avab-shadow-sm);
    }
    .metric strong { display: block; margin-bottom: 8px; color: var(--avab-dark); font-size: 1.3rem; line-height: 1.1; }
    .metric span { color: var(--avab-dark-muted); font-size: 0.92rem; }

    /* ---- Numrerat etappflöde ---- */
    .room-flow {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      margin-top: 28px;
    }

    /* ---- Leveranslista ---- */
    .deliverables { margin-top: 20px; padding: 0; list-style: none; max-width: 860px; }
    .deliverables li {
      position: relative;
      padding: 0 0 14px 26px;
      color: var(--avab-dark-muted);
      font-size: 0.98rem;
    }
    .deliverables li::before { content: "✓"; position: absolute; left: 0; color: var(--avab-green); font-weight: 800; }
    .deliverables li strong { color: var(--avab-dark); }

    /* ---- Citat ---- */
    .testimonial {
      margin: 34px 0 0;
      padding: 32px 36px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-left: 6px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
    }
    .testimonial p { font-size: 1.12rem; font-weight: 600; color: var(--avab-dark); margin-bottom: 8px; line-height: 1.6; }
    .testimonial p + p { margin-top: 14px; }
    .testimonial cite { display: block; margin-top: 16px; font-style: normal; }
    .testimonial cite strong { display: block; color: var(--avab-dark); font-weight: 800; }
    .testimonial cite span { color: var(--avab-dark-muted); font-size: 0.95rem; }

    /* ---- Galleri + bildramar ---- */
    .gallery {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 18px;
      margin-top: 34px;
    }
    .span-7 { grid-column: span 7; }
    .span-6 { grid-column: span 6; }
    .span-5 { grid-column: span 5; }
    .image-frame {
      overflow: hidden;
      border-radius: var(--avab-radius-sm);
      background: var(--avab-grey);
      border: 1px solid var(--avab-border);
    }
    .image-frame img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }
    .image-frame.tall img { aspect-ratio: 4 / 5; }
    .gallery figure, .two-col figure { margin: 0; }
    figcaption { padding-top: 12px; color: var(--avab-dark-muted); font-size: 0.88rem; }

    /* Placeholder tills äkta projektbild läggs in */
    .image-placeholder {
      min-height: 300px;
      display: grid;
      place-items: center;
      padding: 28px;
      border: 2px dashed rgba(40, 46, 42, 0.28);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-grey);
      color: var(--avab-dark-muted);
      text-align: center;
    }
    .image-placeholder strong { display: block; margin-bottom: 8px; color: var(--avab-dark); }
    .image-placeholder small { display: block; font-size: 0.88rem; }

    /* ---- FAQ: vänsterställd rubrik + tvåkolumnslayout ---- */
    .faq-heading { max-width: 760px; margin: 0 0 30px; text-align: left; }
    .faq-heading .eyebrow { margin-left: 0; margin-right: 0; }
    .faq-heading h2 { margin-bottom: 12px; max-width: 680px; }
    .faq-heading p { color: var(--avab-dark-muted); margin-bottom: 0; max-width: 760px; }

    .compact-faq {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 28px;
      row-gap: 0;
      max-width: 1060px;
      margin: 0 auto;
    }
    .compact-faq details.faq-item { padding: 20px 0; }
    .compact-faq summary { font-size: 1.05rem; }
    .compact-faq details.faq-item p { font-size: 0.98rem; }
    .compact-faq details.faq-item:nth-child(1),
    .compact-faq details.faq-item:nth-child(2) { border-top: 1px solid var(--avab-border); }

    .saffle-faq-cta {
      padding-top: 48px;
      padding-bottom: 96px;
    }
    .saffle-faq-cta .compact-faq {
      margin-bottom: 64px;
    }

    /* ---- Responsivt (sidspecifikt) ---- */
    @media (max-width: 1024px) {
      .zone-grid, .metrics, .room-flow { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 768px) {
      .zone-grid, .metrics, .room-flow { grid-template-columns: 1fr; }
      .span-7, .span-6, .span-5 { grid-column: span 12; }
      .compact-faq { grid-template-columns: 1fr; }
      .compact-faq details.faq-item:nth-child(2) { border-top: none; }
      .saffle-faq-cta {
        padding-top: 40px;
        padding-bottom: 72px;
      }
      .saffle-faq-cta .compact-faq {
        margin-bottom: 44px;
      }
    }
  </style>
</head>
<body>
  <SiteHeader />

  <nav class="breadcrumbs" aria-label="Brödsmulor">
    <div class="avab-container">
      <ol>
        <li><a href="https://www.avab.eu/">Start</a></li>
        <li><a href="https://www.avab.eu/referenser/">Referenser</a></li>
        <li><span aria-current="page">Säffle simhall</span></li>
      </ol>
    </div>
  </nav>

  <!-- Lägg bilden i /assets när den flyttas från biblioteket -->
  <section class="hero" style="--hero-image:url('/assets/avab-referens-saffle-simhall-1200x800.webp');">
    <div class="avab-container">
      <div class="hero-inner animate-in">
        <div class="eyebrow">Referensprojekt · Säffle simhall</div>

        <h1>Ett överordnat Crestronsystem för hela anläggningen</h1>

        <p class="lead">
          I Säffle nya simhall ansvarade AVAB för full projektering och installation av AV-tekniken: ett överordnat Crestronsystem, zonindelat ljud, trådlösa mikrofoner, ingjutna hörslingor, projektor och styrning av den visuella miljöbelysningen. När arbetet inleddes var det AVAB:s då största projekt.
        </p>

        <div class="hero-bottom">
          <div class="hero-actions">
            <a class="button button-primary" href="#leveransen">Se leveransen</a>
            <a class="button button-secondary" href="/kontakt/#ladda-upp-underlag">Planerar ni simhall?</a>
            <a class="button button-quiet" href="tel:+46548202080">Ring 054-8202080</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="fact-band" aria-label="Projektfakta">
    <div class="fact-grid">
      <div class="fact"><span>Beställare</span><strong>Assemblin El AB</strong></div>
      <div class="fact"><span>Slutkund</span><strong>SäffleBostäder (SÄBO)</strong></div>
      <div class="fact"><span>Nav</span><strong>Överordnat Crestronsystem</strong></div>
      <div class="fact"><span>Ljud</span><strong>Drygt 50 högtalare, zonindelat</strong></div>
      <div class="fact"><span>Tillgänglighet</span><strong>Ingjutna hörslingor</strong></div>
      <div class="fact"><span>Besparing</span><strong>Upp till 487 tim/år</strong></div>
    </div>
  </section>

  <main id="main">
    <section class="section section--light" id="leveransen">
      <div class="avab-container two-col align-start">
        <div class="animate-in">
          <div class="eyebrow">Vad levererade AVAB?</div>
          <h2>Full projektering och installation av AV-tekniken</h2>
          <p class="lead-dark">AVAB ansvarade för hela AV-leveransen i Säffle simhall och band ihop <a class="text-link" href="/tjanster/ljudsystem/">ljud</a>, <a class="text-link" href="/tjanster/mikrofoner/">mikrofoner</a>, bild, hörslingor och belysning under ett gemensamt <a class="text-link" href="/tjanster/styrsystem-integration/">Crestron-styrsystem</a>.</p>
          <ul class="deliverables">
            <li><strong>Överordnat Crestronsystem</strong> som samlar drift, ljud, ljus och information.</li>
            <li><strong>Zonindelad ljudanläggning</strong> efter hur lokalerna faktiskt används.</li>
            <li><strong>Trådlösa mikrofoner</strong> för tal, speaker och evenemang.</li>
            <li><strong>Ingjutna hörslingor</strong> vid läktarna för tillgängligt ljud.</li>
            <li><strong>Projektor</strong> i multihallen för aktiviteter och visning.</li>
            <li><strong>Styrning av RGB-belysning</strong> vid barnpool, relaxpool och konstverket Forest of Säffle.</li>
          </ul>
        </div>

        <aside class="snippet-box animate-in">
          <span class="label">Kort svar för sök och AI</span>
          <h3>Vad levererade AVAB till Säffle simhall?</h3>
          <p>AVAB ansvarade för full projektering och installation av AV-tekniken: ett överordnat Crestronsystem, en zonindelad ljudanläggning, trådlösa mikrofoner, ingjutna hörslingor, projektor och styrning av den visuella miljöbelysningen.</p>
        </aside>
      </div>
    </section>

    <section class="section" id="zoner">
      <div class="avab-container">
        <div class="section-heading animate-in">
          <div>
            <div class="eyebrow">Zonindelat ljud</div>
            <h2>Ljudet delades in efter hur lokalerna faktiskt används</h2>
            <p class="lead-dark">En simhall är många miljöer i en. 50-metershallen, barnpoolen, relaxen och receptionen har helt olika behov av nivå, källa och karaktär. Därför projekterades <a class="text-link" href="/tjanster/ljudsystem/">ljudanläggningen</a> i separata zoner som Crestronsystemet styr var för sig.</p>
          </div>
        </div>
        <div class="zone-grid">
          <article class="zone"><b>50-metershallen</b><span>Separata zoner mot bassängen och läktarna för både tävling och vardag.</span></article>
          <article class="zone"><b>Barnpoolsområdet</b><span>Egen ljudzon och RGB-belysning som Crestronsystemet styr.</span></article>
          <article class="zone"><b>Relaxavdelningen</b><span>Lugnare ljudmiljö, samordnad med relaxpoolens ljussättning.</span></article>
          <article class="zone"><b>Multihallen</b><span>Ljud och projektor för aktiviteter, visning och evenemang.</span></article>
          <article class="zone"><b>Lounge</b><span>Bakgrundsljud som följer verksamhetens dag.</span></article>
          <article class="zone"><b>Reception och café</b><span>Välkomnande ljud i entrézonen där besökarna möts.</span></article>
        </div>
        <aside class="snippet-box">
          <span class="label">Utöver ljudet</span>
          <h3>Vad samlar Crestronsystemet?</h3>
          <p>Öppning och stängning av anläggningen, ljudkällor och volym i respektive zon, RGB-belysningen vid barnpool och relaxpool samt ljussättningen av konstverket Forest of Säffle. Systemet visar även larm, öppna och stängda dörrar och annan ansluten driftinformation.</p>
        </aside>
      </div>
    </section>

    <section class="section section--light" id="tidigt">
      <div class="avab-container two-col align-start">
        <figure class="animate-in">
          <div class="image-placeholder"><div><strong>BILDPLATS: Ingjutning av rör och hörslingor</strong><small>Egen bild: rör i betong eller hörslinga vid läktare under byggfasen</small></div></div>
          <figcaption>Rören till högtalarna och hörslingorna vid läktarna behövde projekteras och gjutas in i betongen långt innan resten av tekniken kom på plats.</figcaption>
        </figure>
        <div class="animate-in">
          <div class="eyebrow">Två år före invigning</div>
          <h2>Det var redan bråttom när vi fick handlingarna</h2>
          <p class="lead-dark">När AVAB fick förfrågningsunderlaget återstod ungefär två år till färdig anläggning. Trots det brann det redan i knutarna: rören till högtalarna behövde projekteras och gjutas in i betongen, samtidigt som hörslingornas placering och kabeldragning skulle fastställas.</p>
          <p>Vi projekterade högtalarnas placering för jämn ljudspridning och tydlig <a class="text-link" href="/tjanster/taluppfattbarhet-akustik/">taluppfattbarhet</a> i de olika bassäng- och publikområdena. Samtidigt projekterades hörslingorna som skulle gjutas in vid läktarna.</p>
          <p>Det illustrerar både tjusningen och svårigheten med stora simhallsprojekt. När AV-tekniken första gången når installatören finns ofta redan någon annans lösning beskriven i ett FFU, och många avgörande beslut är då fattade. Ett överordnat styrsystem bör egentligen finnas med redan under program- och systemhandlingen, eftersom funktionerna påverkar arkitektur, el, KNX, dörrmiljöer, sensorer, kabelvägar och kommunens krav på hur anläggningen ska drivas. Det är kärnan i varför vår <a class="text-link" href="/tjanster/projektering/">projektering</a> vill in tidigt.</p>
        </div>
      </div>
    </section>

    <section class="section" id="tidsvinsten">
      <div class="avab-container">
        <div class="section-heading animate-in">
          <div>
            <div class="eyebrow">Tidsvinsten</div>
            <h2>Upp till 487 sparade arbetstimmar per år</h2>
            <p class="lead-dark">I Säffle tog den manuella rundan ungefär 30–40 minuter vid öppning och lika lång tid vid stängning. Med Crestronsystemet kan de samordnade funktionerna i stället hanteras från samma panel.</p>
          </div>
        </div>

        <div class="time-table-wrap">
          <table class="time-table">
            <thead><tr><th>Moment</th><th>Tid</th></tr></thead>
            <tbody>
              <tr><td>Manuell öppning</td><td>30–40 minuter</td></tr>
              <tr><td>Manuell stängning</td><td>30–40 minuter</td></tr>
              <tr><td>Total tid per dag</td><td>60–80 minuter</td></tr>
              <tr class="highlight"><td>Möjlig besparing vid daglig drift</td><td>365–487 timmar per år</td></tr>
            </tbody>
          </table>
