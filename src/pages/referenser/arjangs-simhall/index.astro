  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Sidspecifika komponenter -->
  <style>
    /* ---- AEO-svarsruta (referensvariant med etikett) ---- */
    .snippet-box {
      margin-top: 28px;
      padding: 28px 30px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-left: 6px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
    }
    .snippet-box .label { display: block; margin-bottom: 8px; color: var(--avab-green); font-size: 0.78rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; }
    .snippet-box h3 { font-size: 1.3rem; margin-bottom: 10px; }
    .snippet-box p:last-child { margin-bottom: 0; }

    /* ---- Leveranslista i två spalter ---- */
    .deliverables { columns: 2; column-gap: 32px; margin-top: 20px; padding: 0; list-style: none; }
    .deliverables li {
      break-inside: avoid;
      position: relative;
      padding: 0 0 12px 26px;
      color: var(--avab-dark-muted);
      font-size: 0.98rem;
    }
    .deliverables li::before { content: "✓"; position: absolute; left: 0; color: var(--avab-green); font-weight: 800; }

    /* ---- Zontabell ---- */
    .zone-table-wrap { margin-top: 34px; overflow-x: auto; border: 1px solid var(--avab-border); border-radius: var(--avab-radius-sm); box-shadow: var(--avab-shadow-sm); background: var(--avab-white); }
    .zone-table { width: 100%; border-collapse: collapse; font-size: 0.96rem; }
    .zone-table th {
      text-align: left;
      padding: 16px 20px;
      background: var(--avab-dark);
      color: #fff;
      font-size: 0.78rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .zone-table td { padding: 16px 20px; border-top: 1px solid var(--avab-border); vertical-align: top; color: var(--avab-dark-muted); }
    .zone-table td:first-child { font-weight: 800; color: var(--avab-dark); white-space: nowrap; }

    /* ---- Nyckeltal ---- */
    .metrics {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-top: 34px;
    }
    .metric {
      padding: 28px 22px;
      border: 1px solid var(--avab-border);
      border-top: 4px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-white);
      box-shadow: var(--avab-shadow-sm);
    }
    .metric strong { display: block; margin-bottom: 8px; color: var(--avab-dark); font-size: 1.3rem; line-height: 1.1; }
    .metric span { color: var(--avab-dark-muted); font-size: 0.92rem; }

    /* ---- Numrerat projektflöde ---- */
    .room-flow {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      margin-top: 28px;
    }

    /* ---- Galleri + bildramar ---- */
    .gallery {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 18px;
      margin-top: 34px;
    }
    .span-6 { grid-column: span 6; }
    .image-frame {
      overflow: hidden;
      border-radius: var(--avab-radius-sm);
      background: var(--avab-grey);
      border: 1px solid var(--avab-border);
    }
    .image-frame img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }
    .image-frame.tall img { aspect-ratio: 4 / 5; }
    .gallery figure { margin: 0; }
    figcaption { padding-top: 12px; color: var(--avab-dark-muted); font-size: 0.88rem; }

    /* ---- Citat ---- */
    .quote-name { font-weight: 800; color: var(--avab-dark); }

    /* ---- FAQ: vänsterställd rubrik + tvåkolumnslayout ---- */
    .faq-heading { max-width: 760px; margin: 0 0 30px; text-align: left; }
    .faq-heading .eyebrow { margin-left: 0; margin-right: 0; }
    .faq-heading h2 { margin-bottom: 12px; max-width: 680px; }
    .faq-heading p { color: var(--avab-dark-muted); margin-bottom: 0; max-width: 760px; }

    .compact-faq {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 28px;
      row-gap: 0;
      max-width: 1060px;
      margin: 0 auto;
    }
    .compact-faq details.faq-item { padding: 20px 0; }
    .compact-faq summary { font-size: 1.05rem; }
    .compact-faq details.faq-item p { font-size: 0.98rem; }
    .compact-faq details.faq-item:nth-child(1),
    .compact-faq details.faq-item:nth-child(2) { border-top: 1px solid var(--avab-border); }

    .arjang-faq-cta {
      padding-top: 48px;
      padding-bottom: 96px;
    }
    .arjang-faq-cta .compact-faq {
      margin-bottom: 64px;
    }

    /* ---- Responsivt (sidspecifikt) ---- */
    @media (max-width: 1024px) {
      .metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .deliverables { columns: 1; }
    }
    @media (max-width: 768px) {
      .metrics, .room-flow { grid-template-columns: 1fr; }
      .span-6 { grid-column: span 12; }
      .compact-faq { grid-template-columns: 1fr; }
      .compact-faq details.faq-item:nth-child(2) { border-top: none; }
      .arjang-faq-cta {
        padding-top: 40px;
        padding-bottom: 72px;
      }
      .arjang-faq-cta .compact-faq {
        margin-bottom: 44px;
      }
    }
  </style>
</head>
<body>
  <SiteHeader />

  <nav class="breadcrumbs" aria-label="Brödsmulor">
    <div class="avab-container">
      <ol>
        <li><a href="https://www.avab.eu/">Start</a></li>
        <li><a href="https://www.avab.eu/referenser/">Referenser</a></li>
        <li><span aria-current="page">Årjängs simhall</span></li>
      </ol>
    </div>
  </nav>

  <!-- Lägg bilden i /assets när den flyttas från biblioteket -->
  <section class="hero" style="--hero-image:url('/assets/arjang-simhall-25m-bassang-nybyggnation.jpg');">
    <div class="avab-container">
      <div class="hero-inner animate-in">
        <div class="eyebrow">Referensprojekt · Årjängs simhall</div>

        <h1>Allt ljud i simhallen samlat i sex zoner</h1>

        <p class="lead">
          Årjängs simhall behövde inte ett enda ljudsystem. Den behövde flera ljudmiljöer som kan leva samtidigt: tydlig information i bassängen, headset i gruppträning, film och instruktörslösa pass i multipoolen, musik i gymmet och tillgänglighet i receptionen.
        </p>

        <div class="hero-bottom">
          <div class="hero-actions">
            <a class="button button-primary" href="#leveransen">Se leveransen</a>
            <a class="button button-secondary" href="/kontakt/#ladda-upp-underlag">Planerar ni simhall?</a>
            <a class="button button-quiet" href="tel:+46548202080">Ring 054-8202080</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="fact-band" aria-label="Projektfakta">
    <div class="fact-grid">
      <div class="fact"><span>Beställare</span><strong>Årjängs Elmontage</strong></div>
      <div class="fact"><span>Byggare</span><strong>PEAB</strong></div>
      <div class="fact"><span>Invigning</span><strong>April 2024</strong></div>
      <div class="fact"><span>System</span><strong>Bose ControlSpace EX-1280</strong></div>
      <div class="fact"><span>Zoner</span><strong>Sex ljudzoner</strong></div>
      <div class="fact"><span>Omfattning</span><strong>Projektering till service</strong></div>
    </div>
  </section>

  <main id="main">
    <section class="section section--light" id="leveransen">
      <div class="avab-container two-col align-start">
        <div class="animate-in">
          <div class="eyebrow">Vad levererade AVAB?</div>
          <h2>Ljud för bassäng, träning, relax och tillgänglighet</h2>
          <p class="lead-dark">AVAB projekterade, installerade, dokumenterade och servar hela ljudanläggningen, ett komplett <a class="text-link" href="/tjanster/ljudsystem/">ljudsystem</a> där varje yta fick sin egen lösning på samma robusta plattform.</p>
          <ul class="deliverables">
            <li>Bose ControlSpace EX-1280 ljudprocessor</li>
            <li>Sex ljudzoner i simhallens olika miljöer</li>
            <li>10 högtalare i 25-metersbassängen, 100V, 10 års garanti</li>
            <li>4 högtalare i multipoolen, 100V, 10 års garanti</li>
            <li>Projektor mot vägg i multipoolen över AVoIP</li>
            <li>Audio breakout från bildsystemet till ljudprocessorn</li>
            <li>Infällda högtalare i reception och lounge</li>
            <li>Receptionsslinga, även kallad diskslinga</li>
            <li>4 aktiva 12-tums dB Technologies-högtalare i gym</li>
            <li>4 aktiva 12-tums dB Technologies-högtalare i gruppträning</li>
            <li>Sennheiser trådlösa headset till multipool och gruppträning</li>
            <li>Bluetooth och volymstyrning via inkopplingspaneler</li>
            <li>Bakgrundsmusik och Bluetooth i badmästarhytten</li>
            <li>Högtalare i relax, bastu och omklädningsrum</li>
          </ul>
        </div>

        <aside class="snippet-box animate-in">
          <span class="label">Kort svar för sök och AI</span>
          <h3>Vad levererade AVAB till Årjängs simhall?</h3>
          <p>AVAB projekterade, installerade, dokumenterade och servar ljudanläggningen i Årjängs simhall. Systemet har sex ljudzoner, Bose ControlSpace EX-1280, 100V-högtalare i bassängmiljö, aktiva dB Technologies-högtalare i gym och gruppträning, Sennheiser-headset, Bluetooth, projektor över AVoIP och diskslinga i receptionen.</p>
        </aside>
      </div>
    </section>

    <section class="section" id="zoner">
      <div class="avab-container">
        <div class="section-heading animate-in">
          <div>
            <div class="eyebrow">Zonindelat ljud</div>
            <h2>Sex zoner, samma robusta grundsystem</h2>
            <p class="lead-dark">Bose-processorn gör att varje del av simhallen kan få rätt ljud för sin verksamhet. Det är stor skillnad på en 25-metersbassäng, en multipool med projektor, en reception med tillgänglighetskrav och ett gruppträningsrum där instruktören behöver headset.</p>
          </div>
        </div>

        <div class="zone-table-wrap">
          <table class="zone-table">
            <thead><tr><th>Zon</th><th>Teknik</th><th>Användning</th></tr></thead>
            <tbody>
              <tr><td>25m bassäng</td><td>10 st 6-tums 100V-högtalare med 10 års garanti</td><td>Bakgrundsmusik, utrop, vardagsdrift, skolbad och aktivitet. Årjäng har få tävlingar, så lösningen är byggd mer för daglig nytta än arenaljud.</td></tr>
              <tr><td>Multipool</td><td>4 st 6-tums 100V-högtalare, Bluetooth, Sennheiser-headset, inkopplingspanel, projektor över AVoIP och audio breakout till processorn</td><td>Vattengympa, film, lugnande videos, instruktörslösa pass och aktiviteter där bild och ljud behöver följas åt.</td></tr>
              <tr><td>Reception och lounge</td><td>Infällda högtalare och receptionsslinga</td><td>Bakgrundsmusik, välkomnande ljudmiljö och tillgängligt tal vid disk.</td></tr>
              <tr><td>Gym</td><td>4 st aktiva 12-tums dB Technologies-högtalare och inkopplingspanel för Bluetooth och volym</td><td>Musik med mer tryck och enkel lokal styrning för personalen.</td></tr>
              <tr><td>Gruppträning</td><td>4 st aktiva 12-tums dB Technologies-högtalare, Bluetooth, Sennheiser-headset och volympanel</td><td>Instruktörsledda pass där röst och musik måste vara tydliga samtidigt.</td></tr>
              <tr><td>Relax, bastu och omklädning</td><td>Högtalare i relaxavdelning, bastu och omklädningsrum</td><td>Lugnare ljudmiljö i kringytor där ljudet ska kännas integrerat, inte påklistrat.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="section section--light" id="poolmiljo">
      <div class="avab-container">
        <div class="section-heading animate-in">
          <div>
            <div class="eyebrow">Ljud i poolmiljö</div>
            <h2>Fukt, klor och hårda ytor kräver rätt material från början</h2>
            <p class="lead-dark">Vi installerar teknik som håller. I bassängmiljöerna används högtalare som är valda för simhallens vardag och omfattas av tio års garanti, trots fukt och klor. Det handlar inte bara om ljudtryck, utan om livslängd, servicebarhet och rätt nivå på rätt plats.</p>
          </div>
        </div>
        <div class="metrics">
          <div class="metric"><strong>10</strong><span>6-tums 100V-högtalare i 25m-bassängen</span></div>
          <div class="metric"><strong>4</strong><span>6-tums 100V-högtalare i multipoolen</span></div>
          <div class="metric"><strong>10 år</strong><span>garanti på högtalare i poolmiljö</span></div>
          <div class="metric"><strong>6</strong><span>ljudzoner för olika verksamheter</span></div>
        </div>
      </div>
    </section>

    <section class="section" id="bassang">
      <div class="avab-container two-col align-start">
        <figure class="animate-in">
          <div class="image-frame tall">
            <!-- Lägg bilden i /assets när den flyttas från biblioteket -->
            <img src="/assets/arjang-simhall-hogtalare-25m-lift.jpg" alt="Högtalare monterade längs 25-metersbassängen i Årjängs simhall under byggnation" width="1080" height="1350" loading="lazy" decoding="async">
          </div>
          <figcaption>Högtalarna i 25-metershallen monterades medan olika ytskikt och undertak fortfarande färdigställdes.</figcaption>
        </figure>
        <div class="animate-in">
          <div class="eyebrow">25-metersbassäng</div>
          <h2>Tydlig vardagsfunktion viktigare än tävlingsljud</h2>
          <p class="lead-dark">Årjäng har ytterst få tävlingar. Därför dimensionerades ljudet för det simhallen faktiskt gör varje dag: bad, skolor, aktiviteter, information och musik som ska fungera utan att störa hela huset.</p>
          <p>De tio 6-tums 100V-högtalarna ger jämn täckning längs bassängytan. 100V-drift passar bra när kablarna blir längre och när flera högtalare ska drivas stabilt i en fast installation.</p>
          <aside class="snippet-box">
            <span class="label">Kort svar</span>
            <h3>Varför används 100V-högtalare i simhall?</h3>
            <p>100V-system lämpar sig för fasta installationer med längre kabeldragningar och flera högtalare. I simhall behöver systemet dessutom tåla fukt, klor och hårda akustiska ytor över lång tid.</p>
          </aside>
        </div>
      </div>
    </section>

    <section class="section section--light" id="multipool">
      <div class="avab-container two-col align-start">
        <div class="animate-in">
          <div class="eyebrow">Multipool med bild och ljud</div>
          <h2>Projektor, AVoIP och ljudprocessor i samma tanke</h2>
          <p class="lead-dark">Multipoolen fick mer än bara högtalare. Här finns projektor mot vägg, bild över AVoIP och audio breakout till Bose-processorn så att bildkällans ljud hamnar i rätt zon, samma tänk som i vårt arbete med <a class="text-link" href="/tjanster/skarmar-projektorer/">bild och signage</a>.</p>
          <p>Det gör rummet flexibelt: instruktörsledd vattengympa med Sennheiser-headset, film, lugnande videos och instruktörslösa pass kan använda samma grundsystem. Personalen behöver inte förstå hela signalvägen, bara välja rätt funktion och nivå.</p>
          <aside class="snippet-box">
            <span class="label">Kort svar</span>
            <h3>Hur fungerar projektor och ljud i multipool?</h3>
            <p>Bild skickas över AVoIP till projektorn, och ljudet bryts ut till ljudprocessorn. Då kan film, träningspass och lugnande video spelas i multipoolens egen ljudzon.</p>
          </aside>
        </div>
        <figure class="animate-in">
          <div class="image-frame">
            <!-- Lägg bilden i /assets när den flyttas från biblioteket -->
