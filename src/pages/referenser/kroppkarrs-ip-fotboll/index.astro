  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Varför inte bara en stor högtalare?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Två zoner ger bättre kontroll. Huvudplan och B-plan kan användas separat, och ljudet behöver inte skickas över ytor där det inte behövs."
        }
      },
      {
        "@type": "Question",
        "name": "Varför används 100V-system?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "100V är praktiskt för fasta installationer och längre kabeldragningar, särskilt när högtalarna sitter långt från förstärkare och styrning."
        }
      },
      {
        "@type": "Question",
        "name": "Varför sitter pairing-knappen innanför dörren?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "För att systemet ska vara enkelt för behöriga användare, men inte öppet för vem som helst som står utanför och försöker ansluta."
        }
      },
      {
        "@type": "Question",
        "name": "Kan samma lösning användas på andra idrottsplatser?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Principen med rätt högtalare per yta, tydliga zoner och skyddad styrning fungerar för många typer av utomhusanläggningar."
        }
      }
    ]
  }
  </script>

