  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Preload av hero-bilden för snabbare LCP -->
  <link rel="preload" as="image" fetchpriority="high"
    href="/assets/lesjofors-konferensrum-fardigt-langbord.webp"
    imagesrcset="/assets/lesjofors-konferensrum-fardigt-langbord.webp 1280w"
    imagesizes="100vw">

  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Sidspecifika komponenter -->
  <style>
    /* ---- AEO-svarsruta (referensvariant med etikett) ---- */
    .snippet-box {
      margin-top: 28px;
      padding: 28px 30px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-left: 6px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
    }
    .snippet-box .label { display: block; margin-bottom: 8px; color: var(--avab-green); font-size: 0.78rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; }
    .snippet-box h3 { font-size: 1.3rem; margin-bottom: 10px; }
    .snippet-box p:last-child { margin-bottom: 0; }

    /* ---- Nyckeltal ---- */
    .metrics {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-top: 34px;
    }
    .metric {
      padding: 28px 22px;
      border: 1px solid var(--avab-border);
      border-top: 4px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-white);
      box-shadow: var(--avab-shadow-sm);
    }
    .metric strong { display: block; margin-bottom: 8px; color: var(--avab-dark); font-size: 1.3rem; line-height: 1.1; }
    .metric span { color: var(--avab-dark-muted); font-size: 0.92rem; }

    /* ---- Användarflöde (trådlöst eller USB-C) ---- */
    .signal-flow {
      display: grid;
      grid-template-columns: 1fr auto 1fr auto 1fr;
      gap: 16px;
      align-items: center;
      margin-top: 28px;
    }
    .signal-node {
      min-height: 96px;
      display: grid;
      place-items: center;
      padding: 18px;
      border: 1px solid var(--avab-border);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-white);
      box-shadow: var(--avab-shadow-sm);
      text-align: center;
      font-weight: 700;
    }
    .signal-arrow { color: var(--avab-green); font-size: 1.15rem; font-weight: 800; text-align: center; text-transform: uppercase; letter-spacing: 0.03em; }

    /* ---- Galleri + bildramar ---- */
    .gallery {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 18px;
      margin-top: 34px;
    }
    .span-7 { grid-column: span 7; }
    .span-6 { grid-column: span 6; }
    .span-5 { grid-column: span 5; }
    .image-frame {
      overflow: hidden;
      border-radius: var(--avab-radius-sm);
      background: var(--avab-grey);
      border: 1px solid var(--avab-border);
    }
    .image-frame img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }
    .gallery figure, .two-col figure { margin: 0; }
    figcaption { padding-top: 12px; color: var(--avab-dark-muted); font-size: 0.88rem; }

    /* Placeholder tills äkta projektbild läggs in */
    .image-placeholder {
      min-height: 300px;
      display: grid;
      place-items: center;
      padding: 28px;
      border: 2px dashed rgba(40, 46, 42, 0.28);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-grey);
      color: var(--avab-dark-muted);
      text-align: center;
    }
    .image-placeholder strong { display: block; margin-bottom: 8px; color: var(--avab-dark); }
    .image-placeholder small { display: block; font-size: 0.88rem; }

    /* ---- FAQ: vänsterställd rubrik + tvåkolumnslayout ---- */
    .faq-heading { max-width: 760px; margin: 0 0 30px; text-align: left; }
    .faq-heading .eyebrow { margin-left: 0; margin-right: 0; }
    .faq-heading h2 { margin-bottom: 12px; max-width: 680px; }
    .faq-heading p { color: var(--avab-dark-muted); margin-bottom: 0; max-width: 760px; }

    .compact-faq {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 28px;
      row-gap: 0;
      max-width: 1060px;
      margin: 0 auto;
    }
    .compact-faq details.faq-item { padding: 20px 0; }
    .compact-faq summary { font-size: 1.05rem; }
    .compact-faq details.faq-item p { font-size: 0.98rem; }
    .compact-faq details.faq-item:nth-child(1),
    .compact-faq details.faq-item:nth-child(2) { border-top: 1px solid var(--avab-border); }

    .lesjofors-faq-cta {
      padding-top: 48px;
      padding-bottom: 96px;
    }
    .lesjofors-faq-cta .compact-faq {
      margin-bottom: 64px;
    }

    /* ---- Responsivt (sidspecifikt) ---- */
    @media (max-width: 1024px) {
      .metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .signal-flow { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .metrics { grid-template-columns: 1fr; }
      .span-7, .span-6, .span-5 { grid-column: span 12; }
      .image-placeholder { min-height: 240px; }
      .compact-faq { grid-template-columns: 1fr; }
      .compact-faq details.faq-item:nth-child(2) { border-top: none; }
      .lesjofors-faq-cta {
        padding-top: 40px;
        padding-bottom: 72px;
      }
      .lesjofors-faq-cta .compact-faq {
        margin-bottom: 44px;
      }
    }
  </style>
</head>
<body>
  <SiteHeader />

  <nav class="breadcrumbs" aria-label="Brödsmulor">
    <div class="avab-container">
      <ol>
        <li><a href="https://www.avab.eu/">Start</a></li>
        <li><a href="https://www.avab.eu/referenser/">Referenser</a></li>
        <li><span aria-current="page">Lesjöfors AB</span></li>
      </ol>
    </div>
  </nav>

  <!-- Lägg bilden i /assets när den flyttas från biblioteket -->
  <section class="hero" style="--hero-image:url('/assets/lesjofors-konferensrum-fardigt-langbord.webp');">
    <div class="avab-container">
      <div class="hero-inner animate-in">
        <div class="eyebrow">Referensprojekt · Lesjöfors AB, Lesjöfors</div>

        <h1>Ett konferensrum för globala möten, byggt i Lesjöfors</h1>

        <p class="lead">
          Lesjöfors AB är en stor industriverksamhet med drift kvar i Lesjöfors och kontakter långt utanför orten. AVAB byggde ett mötesrum där användaren kan presentera trådlöst direkt, eller koppla in en USB-C-kabel för videokonferens som samtidigt laddar datorn.
        </p>

        <div class="hero-bottom">
          <div class="hero-actions">
            <a class="button button-primary" href="#leveransen">Se lösningen</a>
            <a class="button button-secondary" href="/kontakt/#ladda-upp-underlag">Planerar ni mötesrum?</a>
            <a class="button button-quiet" href="tel:+46548202080">Ring 054-8202080</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="fact-band" aria-label="Projektfakta">
    <div class="fact-grid">
      <div class="fact"><span>Miljö</span><strong>Konferensrum</strong></div>
      <div class="fact"><span>Kund</span><strong>Lesjöfors AB, Lesjöfors</strong></div>
      <div class="fact"><span>Display</span><strong>86 tum 4K</strong></div>
      <div class="fact"><span>Ljudnav</span><strong>Q-SYS med AEC och Dante</strong></div>
      <div class="fact"><span>Mikrofon</span><strong>Takarray, 32 zoner</strong></div>
      <div class="fact"><span>Anslutning</span><strong>Trådlöst eller USB-C</strong></div>
    </div>
  </section>

  <main id="main">
    <section class="section section--light" id="leveransen">
      <div class="avab-container two-col align-start">
        <div class="animate-in">
          <div class="eyebrow">Vad levererade AVAB?</div>
          <h2>Konferensteknik där en kabel räcker för videomötet</h2>
          <p class="lead-dark">Målet var ett mötesrum som är enkelt för vardagsanvändaren, men byggt med en teknisk nivå som klarar tydligt ljud, bra kamerabild och stabil signalhantering även när rummet används av många olika personer.</p>
          <ul class="bullet-list">
            <li>Vestel 86-tums 4K-display, 500 nits, 24/7-drift, liggande eller stående montering.</li>
            <li>Chief väggfäste med låg profil för ren vägginstallation.</li>
            <li>Q-SYS kontrollprocessor och DSP med AEC, Dante och flexibla ljudkanaler.</li>
            <li>Q-SYS-lösning med Teams-relaterad licensiering och nätverksvideo i systemet.</li>
            <li>Huddly IQ-kamera med automatisk inramning för mötesrummet.</li>
            <li>Audio-Technica takarray med beamforming, DSP, AEC, Dante och 32 pickup-zoner.</li>
            <li>Netgear AV-switch med PoE+ för den nätverksbaserade AV-miljön.</li>
            <li>Infällda Saros 6,5-tums takhögtalare.</li>
            <li>Blaze PowerZone-förstärkare för rumslyssningen.</li>
          </ul>
        </div>

        <aside class="snippet-box animate-in">
          <span class="label">Kort svar för sök och AI</span>
          <h3>Vad gjorde AVAB hos Lesjöfors AB?</h3>
          <p>AVAB byggde ett konferensrum med 86-tums 4K-display, Q-SYS som ljud- och kontrollnav, Audio-Technica beamforming-takmikrofon, Huddly IQ-kamera, Netgear AV-switch, infällda takhögtalare och USB-C för videokonferens med laddning.</p>
        </aside>
      </div>
    </section>

    <section class="section" id="anvandning">
      <div class="avab-container two-col align-start">
        <div class="animate-in">
          <div class="eyebrow">Två sätt att använda rummet</div>
          <h2>Trådlös presentation direkt, eller videomöte via USB-C</h2>
          <p class="lead-dark">Alla möten behöver inte samma start. Ibland ska någon bara visa en ritning, en offert, en produktionsplan eller en webbsida. Då ska presentationen kunna upp på skärmen snabbt. Andra gånger ska rummet bli ett videomöte med kamera, mikrofoner och högtalare.</p>
          <div class="signal-flow" aria-label="Användarflöde i mötesrummet">
            <div class="signal-node">Presentera trådlöst</div>
            <div class="signal-arrow" aria-hidden="true">eller</div>
            <div class="signal-node">Anslut USB-C</div>
            <div class="signal-arrow" aria-hidden="true">→</div>
            <div class="signal-node">Videomöte och laddning</div>
          </div>
          <p style="margin-top: 24px;">USB-C-lösningen gör att användarens dator kan använda rummets kamera, takmikrofon, högtalare och display samtidigt som datorn får laddning. Det är precis den typen av enkelhet, samma som i vår <a class="text-link" href="/tjanster/videomoten-byod/">BYOD-lösning för videomöten</a>, som gör att tekniken faktiskt används.</p>
        </div>
        <figure class="animate-in">
          <div class="image-placeholder"><div><strong>BILDPLATS: Färdigt rum (vid vy)</strong><small>Långbord, 86-tums display och dator i bruk</small></div></div>
          <figcaption>Färdigt rum med stor arbetsyta, 86-tums display och teknik som är tänkt att försvinna in i mötet.</figcaption>
        </figure>
      </div>
    </section>

    <section class="section section--light" id="qsys">
      <div class="avab-container">
        <div class="section-heading animate-in">
          <div>
            <div class="eyebrow">Q-SYS som hjärna</div>
            <h2>När ljud, kamera, nätverk och kontroll måste arbeta som ett system</h2>
            <p class="lead-dark">Q-SYS hanterar ljudprocessning, AEC, Dante, kontroll och signalvägar, som nav i rummets <a class="text-link" href="/tjanster/styrsystem-integration/">styrsystem</a>. Det gör lösningen mer robust än ett rum där varje produkt arbetar för sig.</p>
          </div>
        </div>
        <div class="metrics">
          <div class="metric"><strong>AEC</strong><span>ekokontroll för videomöten</span></div>
          <div class="metric"><strong>Dante</strong><span>nätverksljud mellan enheter</span></div>
          <div class="metric"><strong>32</strong><span>pickup-zoner i takmikrofonen</span></div>
          <div class="metric"><strong>PoE+</strong><span>AV-switch för nätverksbaserad teknik</span></div>
        </div>
      </div>
    </section>

    <section class="section" id="mikrofon">
      <div class="avab-container two-col align-start">
        <figure class="animate-in">
          <div class="image-frame">
            <!-- Lägg bilden i /assets när den flyttas från biblioteket -->
            <img src="/assets/lesjofors-audio-technica-takmikrofon.webp" alt="Audio-Technica takmikrofon monterad i konferensrum hos Lesjöfors AB" width="1280" height="720" loading="lazy" decoding="async">
          </div>
          <figcaption>Audio-Technica takarray med beamforming. Mikrofonen sitter diskret i undertaket och fångar tal runt bordet.</figcaption>
        </figure>
        <div class="animate-in">
          <div class="eyebrow">Takmikrofon med beamforming</div>
          <h2>Bordet hålls rent, men ljudet fångas där människorna sitter</h2>
          <p class="lead-dark">I ett långt mötesrum kan det vara lockande att fylla bordet med mikrofoner. Här valdes istället en takmonterad array med beamforming, DSP, AEC, Q-SYS-integration och Dante, valt enligt samma principer som våra övriga <a class="text-link" href="/tjanster/mikrofoner/">mikrofonlösningar</a>.</p>
          <p>Takmikrofonens 32 pickup-zoner gör att systemet kan fokusera på tal från mötesdeltagarna utan att varje plats behöver egen bordsmikrofon. Resultatet blir renare bord, färre lösa prylar och ett rum som är lättare att använda.</p>
          <aside class="snippet-box">
            <span class="label">Kort svar</span>
            <h3>Varför välja takmikrofon i konferensrum?</h3>
            <p>En takmikrofon med beamforming fångar tal från mötesdeltagarna utan bordsmikrofoner. Det ger renare bord, mindre handhavande och bättre förutsättningar för videomöten i rum med många sittplatser.</p>
          </aside>
        </div>
      </div>
