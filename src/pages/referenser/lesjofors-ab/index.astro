  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": "https://www.avab.eu/referenser/lesjofors-ab/#faq",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad levererade AVAB till Lesjöfors AB?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AVAB byggde ett konferensrum med 86-tums 4K-display, Q-SYS Core/DSP med AEC och Dante, Audio-Technica beamforming-takmikrofon, Huddly IQ-kamera, Netgear AV-switch, infällda Saros-takhögtalare och Blaze-förstärkare. Rummet kan användas för trådlös presentation eller videokonferens via USB-C."
        }
      },
      {
        "@type": "Question",
        "name": "Hur fungerar USB-C i konferensrummet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En USB-C-kabel kopplar användarens dator till rummets kamera, mikrofon, högtalare och display, samtidigt som datorn laddas. Det gör videomötet enkelt att starta från den egna datorn."
        }
      },
      {
        "@type": "Question",
        "name": "Varför används takmikrofon med beamforming?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En beamforming-takmikrofon kan rikta upptagningen mot personer runt bordet och minska behovet av bordsmikrofoner. I Lesjöfors används en Audio-Technica-array med DSP, AEC, Dante och 32 pickup-zoner."
        }
      },
      {
        "@type": "Question",
        "name": "Vad gör Q-SYS i mötesrummet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Q-SYS fungerar som tekniskt nav för ljud, kontroll, AEC, Dante och signalhantering. Det gör att kamera, mikrofon, högtalare, förstärkare och mötesdator arbetar som ett sammanhållet system."
        }
      },
      {
        "@type": "Question",
        "name": "Varför används Dante?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Dante skickar digitalt ljud över nätverket mellan kompatibla enheter. Det ger flexibel signalhantering och passar bra i system där Q-SYS, mikrofoner och annan AV-teknik ska arbeta tillsammans."
        }
      },
      {
        "@type": "Question",
        "name": "Vad gör Huddly IQ i ett mötesrum?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Huddly IQ är en mötesrumskamera med automatisk inramning. Den hjälper till att visa deltagarna i rummet utan att användaren behöver styra kameran manuellt."
        }
      }
    ]
  }
  </script>

