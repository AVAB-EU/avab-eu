      .compact-faq { grid-template-columns: 1fr; }
      .compact-faq details.faq-item:nth-child(2) { border-top: none; }
      .ekhag-faq-cta { padding-top: 40px; padding-bottom: 72px; }
      .ekhag-faq-cta .compact-faq { margin-bottom: 44px; }
    }
  </style>
</head>
