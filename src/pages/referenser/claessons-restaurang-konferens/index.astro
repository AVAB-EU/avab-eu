    href="/assets/claessons-albatrossen-stor-sal.webp"
    imagesrcset="/assets/claessons-albatrossen-stor-sal.webp 1200w"
    imagesizes="100vw">

  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Sidspecifika komponenter -->
  <style>
    /* ---- AEO-svarsruta (referensvariant med etikett) ---- */
    .snippet-box {
      margin-top: 28px;
      padding: 28px 30px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-left: 6px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
    }
    .snippet-box .label { display: block; margin-bottom: 8px; color: var(--avab-green); font-size: 0.78rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; }
    .snippet-box strong { display: block; font-size: 1.2rem; margin-bottom: 10px; color: var(--avab-dark); }
    .snippet-box p:last-child { margin-bottom: 0; }

    /* ---- Nyckeltal ---- */
    .metrics { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; margin-top: 8px; }
    .metric {
      padding: 28px 22px;
      border: 1px solid var(--avab-border);
      border-top: 4px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-white);
      box-shadow: var(--avab-shadow-sm);
    }
    .metric strong { display: block; margin-bottom: 8px; color: var(--avab-dark); font-size: 1.4rem; line-height: 1.1; }
    .metric span { color: var(--avab-dark-muted); font-size: 0.92rem; }

    /* ---- Utrustningslista (Albatrossen) ---- */
    .deliverables { margin-top: 20px; padding: 0; list-style: none; }
    .deliverables li {
      position: relative;
      padding: 0 0 14px 26px;
      color: var(--avab-dark-muted);
      font-size: 0.98rem;
    }
    .deliverables li::before { content: "✓"; position: absolute; left: 0; color: var(--avab-green); font-weight: 800; }

    /* ---- Områdeskort ---- */
    .scope-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin-top: 28px; }
    .scope {
      padding: 24px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
    }
    .scope b { display: block; margin-bottom: 6px; color: var(--avab-dark); font-size: 1.02rem; }
    .scope span { color: var(--avab-dark-muted); font-size: 0.93rem; line-height: 1.5; }

    /* ---- Galleri + bildramar ---- */
    .gallery { display: grid; grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 18px; margin-top: 34px; }
    .span-7 { grid-column: span 7; }
    .span-6 { grid-column: span 6; }
    .span-5 { grid-column: span 5; }
    .image-frame {
      overflow: hidden;
      border-radius: var(--avab-radius-sm);
      background: var(--avab-grey);
      border: 1px solid var(--avab-border);
    }
    .image-frame img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }
    .gallery figure, .two-col figure { margin: 0; }
    figcaption { padding-top: 12px; color: var(--avab-dark-muted); font-size: 0.88rem; }

    /* Placeholder tills äkta projektbild läggs in */
    .image-placeholder {
      min-height: 300px;
      height: 100%;
      display: grid;
      place-items: center;
      padding: 28px;
      border: 2px dashed rgba(40, 46, 42, 0.28);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-grey);
      color: var(--avab-dark-muted);
      text-align: center;
    }
    .image-placeholder strong { display: block; margin-bottom: 8px; color: var(--avab-dark); }
    .image-placeholder small { display: block; font-size: 0.88rem; }

    /* ---- FAQ: vänsterställd rubrik + tvåkolumnslayout ---- */
    .faq-heading { max-width: 760px; margin: 0 0 30px; text-align: left; }
    .faq-heading .eyebrow { margin-left: 0; margin-right: 0; }
    .faq-heading h2 { margin-bottom: 12px; max-width: 680px; }
    .faq-heading p { color: var(--avab-dark-muted); margin-bottom: 0; max-width: 760px; }

    .compact-faq {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 28px;
      row-gap: 0;
      max-width: 1060px;
      margin: 0 auto;
    }
    .compact-faq details.faq-item { padding: 20px 0; }
    .compact-faq summary { font-size: 1.05rem; }
    .compact-faq details.faq-item p { font-size: 0.98rem; }
    .compact-faq details.faq-item:nth-child(1),
    .compact-faq details.faq-item:nth-child(2) { border-top: 1px solid var(--avab-border); }

    .claessons-faq-cta { padding-top: 48px; padding-bottom: 96px; }
    .claessons-faq-cta .compact-faq { margin-bottom: 64px; }

    /* ---- Responsivt (sidspecifikt) ---- */
    @media (max-width: 1024px) {
      .metrics, .scope-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 768px) {
      .metrics, .scope-grid { grid-template-columns: 1fr; }
      .span-7, .span-6, .span-5 { grid-column: span 12; }
      .compact-faq { grid-template-columns: 1fr; }
      .compact-faq details.faq-item:nth-child(2) { border-top: none; }
      .claessons-faq-cta { padding-top: 40px; padding-bottom: 72px; }
      .claessons-faq-cta .compact-faq { margin-bottom: 44px; }
    }
  </style>
</head>
<body>
  <SiteHeader />

  <nav class="breadcrumbs" aria-label="Brödsmulor">
    <div class="avab-container">
      <ol>
        <li><a href="https://www.avab.eu/">Start</a></li>
        <li><a href="https://www.avab.eu/referenser/">Referenser</a></li>
        <li><span aria-current="page">Claessons Konferens &amp; Restaurang</span></li>
      </ol>
    </div>
  </nav>

  <!-- Lägg bilden i /assets när den flyttas från biblioteket -->
  <section class="hero" style="--hero-image:url('/assets/claessons-albatrossen-stor-sal.webp');">
    <div class="avab-container">
      <div class="hero-inner animate-in">
        <div class="eyebrow">Referensprojekt · Claessons Konferens &amp; Restaurang</div>

        <h1>Claessons Konferens &amp; Restaurang – teknik för möten, mat och fest</h1>

        <p class="lead">
          Hos Claessons möts konferens, restaurang och festvåning i samma anläggning. AVAB har levererat och utvecklat ljud, bild, styrning och konferensteknik under mer än 18 år, från mindre mötesrum till Albatrossen med plats för upp till 200 personer.
        </p>

        <div class="hero-bottom">
          <div class="hero-actions">
            <a class="button button-primary" href="#leveransen">Se leveransen</a>
            <a class="button button-secondary" href="/kontakt/#ladda-upp-underlag">Planerar ni konferens?</a>
            <a class="button button-quiet" href="tel:+46548202080">Ring 054-8202080</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="fact-band" aria-label="Projektfakta">
    <div class="fact-grid">
      <div class="fact"><span>Kund</span><strong>Claessons Konferens &amp; Restaurang</strong></div>
      <div class="fact"><span>Miljö</span><strong>Konferens, restaurang &amp; fest</strong></div>
      <div class="fact"><span>Rum</span><strong>8 konferensrum och lokaler</strong></div>
      <div class="fact"><span>Kapacitet</span><strong>6 till 200 personer</strong></div>
      <div class="fact"><span>Styrning</span><strong>Neets, numera Biamp</strong></div>
      <div class="fact"><span>Relation</span><strong>Kund i över 18 år</strong></div>
    </div>
  </section>

  <main id="main">
    <section class="section section--light" id="leveransen">
      <div class="avab-container two-col align-start">
        <div class="animate-in">
          <div class="eyebrow">En konferensanläggning måste fungera varje dag</div>
          <h2>Lika enkelt för ett litet möte som för en stor konferens</h2>
          <p class="lead-dark">Claessons har åtta konferensrum och samlingslokaler med kapacitet från mindre möten för sex personer till större samlingar för upp till 200. Tekniken behöver därför fungera lika enkelt för ett litet möte som för en stor konferens, utbildning, paneldebatt eller företagsdag.</p>
          <p>AVAB har hjälpt Claessons med ljud, bild, styrning och <a class="text-link" href="/tjanster/konferensteknik/">konferensteknik</a> under mer än 18 år. Det gör projektet till mer än en enskild installation. Det är ett långsiktigt samarbete där tekniken har kompletterats, uppdaterats och anpassats efter verksamhetens behov över tid, en naturlig del av vår <a class="text-link" href="/service-support/">service och support</a>.</p>
        </div>

        <aside class="snippet-box animate-in">
          <span class="label">Kort svar för sök och AI</span>
          <strong>Hur många konferensrum har Claessons?</strong>
          <p>Claessons har åtta konferensrum och samlingslokaler med kapacitet från sex till 200 personer. De tre största har styrsystem, projektor, duk och HDBaseT, och Albatrossen har dessutom trådlösa mikrofoner och möjlighet att ansluta extern mixer.</p>
        </aside>
      </div>
    </section>

    <section class="section" id="konferensrum">
      <div class="avab-container two-col align-start">
        <div class="animate-in">
          <div class="eyebrow">Tre större konferensrum</div>
          <h2>Rummet startas, rätt bildväg aktiveras, lokalen är redo</h2>
          <p class="lead-dark">I de tre större konferensrummen, med kapacitet för cirka 50, 50 och 200 personer, används Neets-styrning, numera Biamp, för att göra tekniken enkel att hantera, byggt på samma principer som våra <a class="text-link" href="/tjanster/styrsystem-integration/">styrsystem</a>.</p>
          <p>I de två mellanstora rummen är projektorduken motoriserad. När användaren startar projektorn åker duken ned automatiskt. I den största salen, Albatrossen, används en fast duk. Det gör att användaren slipper tänka på tekniken bakom: rummet startas, rätt bildväg aktiveras och lokalen blir redo för presentation.</p>
          <aside class="snippet-box">
            <span class="label">Kort svar</span>
            <strong>Varför är styrsystem viktigt i konferensrum?</strong>
            <p>Ett styrsystem gör att användaren kan starta projektor, duk och ljud på ett enkelt sätt utan att behöva förstå tekniken bakom installationen.</p>
          </aside>
        </div>
        <figure class="animate-in">
          <div class="image-placeholder"><div><strong>BILDPLATS: Motoriserad projektorduk</strong><small>Föreslagen fil: claessons-konferensrum-motoriserad-duk.webp</small></div></div>
          <figcaption>Motoriserad projektorduk i ett av Claessons större konferensrum.</figcaption>
        </figure>
      </div>
    </section>

    <section class="section section--light" id="albatrossen">
      <div class="avab-container two-col align-start">
        <figure class="animate-in">
          <div class="image-placeholder"><div><strong>BILDPLATS: Albatrossen</strong><small>Föreslagen fil: claessons-albatrossen-stor-sal.webp</small></div></div>
          <figcaption>Albatrossen, Claessons största konferens- och samlingslokal med plats för upp till 200 personer.</figcaption>
        </figure>
        <div class="animate-in">
          <div class="eyebrow">Albatrossen, den största salen</div>
          <h2>Rustad för större möten, presentationer och paneldebatter</h2>
          <p class="lead-dark">Albatrossen tar upp till 200 personer och har trådlösa mikrofonsystem för större möten, presentationer och paneldebatter.</p>
          <ul class="deliverables">
            <li>En trådlös handmikrofon.</li>
            <li>Två trådlösa headset.</li>
            <li>Fast projektorduk.</li>
            <li>HDBaseT för bildöverföring.</li>
            <li>Möjlighet att ansluta extern mixer vid större arrangemang.</li>
          </ul>
          <p>Möjligheten att koppla in en extern mixer är viktig. Vid större konferenser, debatter eller scenprogram kan man behöva fler <a class="text-link" href="/tjanster/mikrofoner/">mikrofoner</a>, fler ljudkällor eller en tekniker som sköter ljudet mer aktivt. Då finns infrastrukturen redan på plats.</p>
        </div>
      </div>
    </section>

    <section class="section" id="hdbaset">
      <div class="avab-container">
        <div class="section-heading animate-in">
          <div>
            <div class="eyebrow">Bildöverföring</div>
            <h2>HDBaseT för stabil bild över längre avstånd</h2>
            <p class="lead-dark">Bildöverföringen sker med HDBaseT, vilket gör det möjligt att skicka bildsignaler över längre avstånd på ett stabilt sätt. I konferensanläggningar är det särskilt värdefullt eftersom projektor, styrning och anslutningspunkter ofta sitter långt ifrån varandra. För användaren ska det fortfarande kännas enkelt: koppla in datorn, starta systemet och presentera.</p>
          </div>
        </div>
        <div class="metrics">
          <div class="metric"><strong>8</strong><span>konferensrum och samlingslokaler</span></div>
          <div class="metric"><strong>6–200</strong><span>personer i kapacitet</span></div>
          <div class="metric"><strong>HDBaseT</strong><span>stabil bild över långa sträckor</span></div>
          <div class="metric"><strong>18+ år</strong><span>samarbete med AVAB</span></div>
        </div>
        <aside class="snippet-box">
          <span class="label">AEO-svar</span>
          <strong>Varför används HDBaseT i konferensrum?</strong>
          <p>HDBaseT används för att överföra bild och styrsignaler stabilt över längre kabelsträckor. Det passar konferensrum där projektor, styrsystem och inkopplingspunkter ofta sitter långt ifrån varandra.</p>
        </aside>
      </div>
