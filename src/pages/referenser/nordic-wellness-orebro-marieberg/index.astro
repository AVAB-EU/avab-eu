  <!-- Sidspecifika komponenter -->
  <style>
    /* ---- AEO-svarsruta (referensvariant med etikett) ---- */
    .snippet-box {
      margin-top: 28px;
      padding: 28px 30px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-left: 6px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
    }
    .snippet-box .label { display: block; margin-bottom: 8px; color: var(--avab-green); font-size: 0.78rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; }
    .snippet-box strong { display: block; font-size: 1.2rem; margin-bottom: 10px; color: var(--avab-dark); }
    .snippet-box p:last-child { margin-bottom: 0; }

    /* ---- Nyckeltal ---- */
    .metrics { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; margin-top: 8px; }
    .metric {
      padding: 28px 22px;
      border: 1px solid var(--avab-border);
      border-top: 4px solid var(--avab-green);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-white);
      box-shadow: var(--avab-shadow-sm);
    }
    .metric strong { display: block; margin-bottom: 8px; color: var(--avab-dark); font-size: 1.4rem; line-height: 1.1; }
    .metric span { color: var(--avab-dark-muted); font-size: 0.92rem; }

    /* ---- Leveranslista ---- */
    .deliverables { margin-top: 20px; padding: 0; list-style: none; }
    .deliverables li {
      position: relative;
      padding: 0 0 14px 26px;
      color: var(--avab-dark-muted);
      font-size: 0.98rem;
    }
    .deliverables li::before { content: "✓"; position: absolute; left: 0; color: var(--avab-green); font-weight: 800; }

    /* ---- Citatrad ---- */
    .quote-line {
      margin: 30px 0 0;
      padding: 24px 30px;
      border-left: 6px solid var(--avab-green);
      background: var(--avab-white);
      border-top: 1px solid var(--avab-border);
      border-right: 1px solid var(--avab-border);
      border-bottom: 1px solid var(--avab-border);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
      font-weight: 700;
      font-size: 1.2rem;
      color: var(--avab-dark);
      font-style: italic;
    }

    /* ---- Driftskort (teknik och drift) ---- */
    .drift-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin-top: 28px; }
    .drift-card {
      padding: 28px 24px;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-radius: var(--avab-radius-sm);
      box-shadow: var(--avab-shadow-sm);
      position: relative;
      overflow: hidden;
    }
    .drift-card::before { content: ""; position: absolute; inset: 0 auto 0 0; width: 5px; background: var(--avab-green); }
    .drift-card b { display: block; margin-bottom: 8px; color: var(--avab-green); font-size: 1.4rem; font-weight: 800; }
    .drift-card h3 { font-size: 1.12rem; margin-bottom: 6px; }
    .drift-card p { margin: 0; color: var(--avab-dark-muted); font-size: 0.95rem; }

    /* ---- Galleri + bildramar ---- */
    .gallery { display: grid; grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 18px; margin-top: 34px; }
    .span-7 { grid-column: span 7; }
    .span-6 { grid-column: span 6; }
    .span-5 { grid-column: span 5; }
    .image-frame {
      overflow: hidden;
      border-radius: var(--avab-radius-sm);
      background: var(--avab-grey);
      border: 1px solid var(--avab-border);
    }
    .image-frame img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }
    .image-frame.tall img { aspect-ratio: 4 / 5; }
    .gallery figure, .two-col figure { margin: 0; }
    figcaption { padding-top: 12px; color: var(--avab-dark-muted); font-size: 0.88rem; }

    /* Placeholder tills äkta projektbild läggs in */
    .image-placeholder {
      min-height: 300px;
      height: 100%;
      display: grid;
      place-items: center;
      padding: 28px;
      border: 2px dashed rgba(40, 46, 42, 0.28);
      border-radius: var(--avab-radius-sm);
      background: var(--avab-grey);
      color: var(--avab-dark-muted);
      text-align: center;
    }
    .image-placeholder strong { display: block; margin-bottom: 8px; color: var(--avab-dark); }
    .image-placeholder small { display: block; font-size: 0.88rem; }
    .image-placeholder.video { border-style: solid; border-color: var(--avab-border); background: var(--avab-white); }

    /* ---- FAQ: vänsterställd rubrik + tvåkolumnslayout ---- */
    .faq-heading { max-width: 760px; margin: 0 0 30px; text-align: left; }
    .faq-heading .eyebrow { margin-left: 0; margin-right: 0; }
    .faq-heading h2 { margin-bottom: 12px; max-width: 680px; }
    .faq-heading p { color: var(--avab-dark-muted); margin-bottom: 0; max-width: 760px; }

    .compact-faq {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 28px;
      row-gap: 0;
      max-width: 1060px;
      margin: 0 auto;
    }
    .compact-faq details.faq-item { padding: 20px 0; }
    .compact-faq summary { font-size: 1.05rem; }
    .compact-faq details.faq-item p { font-size: 0.98rem; }
    .compact-faq details.faq-item:nth-child(1),
    .compact-faq details.faq-item:nth-child(2) { border-top: 1px solid var(--avab-border); }

    .nordic-faq-cta { padding-top: 48px; padding-bottom: 96px; }
    .nordic-faq-cta .compact-faq { margin-bottom: 64px; }

    /* ---- Responsivt (sidspecifikt) ---- */
    @media (max-width: 1024px) {
      .metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .drift-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .metrics { grid-template-columns: 1fr; }
      .span-7, .span-6, .span-5 { grid-column: span 12; }
      .compact-faq { grid-template-columns: 1fr; }
      .compact-faq details.faq-item:nth-child(2) { border-top: none; }
      .nordic-faq-cta { padding-top: 40px; padding-bottom: 72px; }
      .nordic-faq-cta .compact-faq { margin-bottom: 44px; }
    }
  </style>
</head>
<body>
