  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vilka personuppgifter behandlar AVAB?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AVAB behandlar främst kontaktuppgifter, företagsuppgifter, projektinformation, offert- och orderhistorik, fakturauppgifter, kundkorrespondens samt teknisk information från webbplatsbesök."
        }
      },
      {
        "@type": "Question",
        "name": "Varför behöver AVAB behandla personuppgifter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Uppgifterna används för att hantera offerter, projekt, leveranser, installationer, serviceärenden, fakturering, support, uppföljning och nödvändig kommunikation med kunder och samarbetspartners."
        }
      },
      {
        "@type": "Question",
        "name": "Delar AVAB personuppgifter med andra?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AVAB säljer inte personuppgifter. Uppgifter kan delas med betrodda leverantörer, exempelvis IT-leverantörer, redovisningspartner, systemleverantörer, installatörer eller andra underleverantörer när det krävs för att utföra ett uppdrag."
        }
      },
      {
        "@type": "Question",
        "name": "Hur länge sparas personuppgifter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AVAB sparar personuppgifter så länge de behövs för ändamålet, exempelvis under ett kundförhållande, ett pågående projekt, ett serviceärende eller så länge lagkrav kräver det."
        }
      },
      {
        "@type": "Question",
        "name": "Hur kontaktar jag AVAB om personuppgifter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Du kan kontakta AVAB via e-post på info@avab.eu eller telefon 054-8202080 om du har frågor om personuppgifter, registerutdrag, rättelse, radering eller begränsning av behandling."
        }
      }
    ]
  }
