    <SiteFooter />

    <script>
      const form = document.querySelector("#contact-form");
      const panels = Array.from(document.querySelectorAll("[data-step]"));
      const stepButtons = Array.from(document.querySelectorAll("[data-step-target]"));
      const progressFill = document.querySelector("#progress-fill");
      const progressText = document.querySelector("#progress-text");
      const intentInputs = Array.from(document.querySelectorAll('input[name="intent"]'));
      const intentError = document.querySelector("#intent-error");
      const areaInputs = Array.from(document.querySelectorAll('input[name="area"]'));
      const areaError = document.querySelector("#area-error");
      const conditionalGroups = Array.from(document.querySelectorAll("[data-intent-fields]"));
      const contactError = document.querySelector("#contact-error");
      const replyError = document.querySelector("#reply-error");
      const reviewList = document.querySelector("#review-list");
      const formStatus = document.querySelector("#form-status");
      const copyButton = document.querySelector("#copy-summary");
      const intentLinks = document.querySelectorAll("[data-contact-intent]");

      let currentStep = 1;
      let highestReached = 1;
      let lastSummary = "";

      const intentLabels = {
        project: "Nytt projekt eller offert",
        service: "Service eller felsökning",
        advice: "Rådgivning eller projektering",
        other: "Annat ärende"
      };

      const stepTwoDescriptions = {
        project: "Beskriv miljön, projektläget och vilket resultat ni vill uppnå.",
        service: "Beskriv anläggningen, felet och hur verksamheten påverkas.",
        advice: "Beskriv vad ni behöver reda ut för att kunna fatta nästa beslut.",
        other: "Beskriv ärendet med egna ord så ser vi till att det hamnar rätt."
      };

      const getSelectedIntent = () => {
        const selected = intentInputs.find((input) => input instanceof HTMLInputElement && input.checked);
        return selected instanceof HTMLInputElement ? selected.value : "";
      };

      const setConditionalFields = () => {
        const intent = getSelectedIntent();
        const description = document.querySelector("#step-2-description");

        if (description instanceof HTMLElement) {
          description.textContent = stepTwoDescriptions[intent] || "Frågorna anpassas efter den ärendetyp ni valde.";
        }

        conditionalGroups.forEach((group) => {
          const isActive = group.getAttribute("data-intent-fields") === intent;
          group.hidden = !isActive;

          group.querySelectorAll("input, select, textarea").forEach((control) => {
            if (control instanceof HTMLInputElement || control instanceof HTMLSelectElement || control instanceof HTMLTextAreaElement) {
              control.disabled = !isActive;
              control.required = isActive && control.hasAttribute("data-required");
            }
          });
        });
      };

      const setStep = (step, shouldFocus = true) => {
        currentStep = Math.min(4, Math.max(1, step));
        highestReached = Math.max(highestReached, currentStep);

        panels.forEach((panel) => {
          panel.hidden = Number(panel.getAttribute("data-step")) !== currentStep;
        });

        stepButtons.forEach((button) => {
          const target = Number(button.getAttribute("data-step-target"));
          button.toggleAttribute("disabled", target > highestReached);
          button.classList.toggle("is-complete", target < currentStep);

          if (target === currentStep) button.setAttribute("aria-current", "step");
          else button.removeAttribute("aria-current");
        });

        if (progressFill instanceof HTMLElement) progressFill.style.width = `${currentStep * 25}%`;
        if (progressText instanceof HTMLElement) progressText.textContent = `Steg ${currentStep} av 4`;

        if (currentStep === 2) setConditionalFields();
        if (currentStep === 4) buildReview();

        if (shouldFocus) {
          const activePanel = panels.find((panel) => Number(panel.getAttribute("data-step")) === currentStep);
          const heading = activePanel?.querySelector("h3");
          const progressWrap = document.querySelector(".progress-wrap");

          if (heading instanceof HTMLElement) {
            heading.setAttribute("tabindex", "-1");
            heading.focus({ preventScroll: true });
          }

          // Vänta tills det gamla steget har dolts och det nya steget fått sin slutliga höjd.
          // Därefter flyttas vyn bara till formulärets progressrad – aldrig till den stora
          // sektionsrubriken ovanför formuläret.
          window.requestAnimationFrame(() => {
            window.requestAnimationFrame(() => {
              const scrollTarget = progressWrap instanceof HTMLElement ? progressWrap : activePanel;
              if (!(scrollTarget instanceof HTMLElement)) return;

              const nav = document.querySelector(".site-nav");
              const navHeight = nav instanceof HTMLElement ? nav.getBoundingClientRect().height : 72;
              const targetTop = window.scrollY + scrollTarget.getBoundingClientRect().top - navHeight - 16;
              const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

              window.scrollTo({
                top: Math.max(0, targetTop),
                behavior: reduceMotion ? "auto" : "smooth"
              });
            });
          });
        }
      };

      const validateNativeControls = (panel, report = true) => {
        const controls = Array.from(panel.querySelectorAll("input, select, textarea")).filter((control) => {
          return !control.disabled && control instanceof HTMLElement;
        });

        for (const control of controls) {
          if (
            control instanceof HTMLInputElement ||
            control instanceof HTMLSelectElement ||
            control instanceof HTMLTextAreaElement
          ) {
            control.removeAttribute("aria-invalid");
            if (!control.checkValidity()) {
              control.setAttribute("aria-invalid", "true");
              if (report) control.reportValidity();
              return false;
            }
          }
        }
        return true;
      };

      const validateStep = (step, report = true) => {
        const panel = panels.find((item) => Number(item.getAttribute("data-step")) === step);
        if (!(panel instanceof HTMLElement)) return true;

        if (step === 1) {
          const valid = Boolean(getSelectedIntent());
          intentError?.classList.toggle("is-visible", !valid);
          return valid;
        }

        if (step === 2) {
          const hasArea = areaInputs.some((input) => input instanceof HTMLInputElement && input.checked);
          areaError?.classList.toggle("is-visible", !hasArea);
          if (!hasArea) return false;
          return validateNativeControls(panel, report);
        }

        if (step === 3) {
          if (!validateNativeControls(panel, report)) return false;

          const email = document.querySelector("#email");
          const phone = document.querySelector("#phone");
          const replyMethod = document.querySelector('input[name="replyMethod"]:checked');
          const emailValue = email instanceof HTMLInputElement ? email.value.trim() : "";
          const phoneValue = phone instanceof HTMLInputElement ? phone.value.trim() : "";
          const method = replyMethod instanceof HTMLInputElement ? replyMethod.value : "";
          const hasContact = Boolean(emailValue || phoneValue);

          contactError?.classList.toggle("is-visible", !hasContact);
          if (email instanceof HTMLInputElement) {
            if (!hasContact) email.setAttribute("aria-invalid", "true");
            else email.removeAttribute("aria-invalid");
          }
          if (phone instanceof HTMLInputElement) {
            if (!hasContact) phone.setAttribute("aria-invalid", "true");
            else phone.removeAttribute("aria-invalid");
          }
          if (!hasContact) return false;

          let replyMessage = "";
          if (method === "Telefon" && !phoneValue) replyMessage = "Ange ett telefonnummer när ni väljer telefon som kontaktväg.";
          if (method === "E-post" && !emailValue) replyMessage = "Ange en e-postadress när ni väljer e-post som kontaktväg.";

          if (replyError instanceof HTMLElement) {
            replyError.textContent = replyMessage;
            replyError.classList.toggle("is-visible", Boolean(replyMessage));
          }
          return !replyMessage;
        }

        return true;
      };

      const valueOf = (selector) => {
        const element = document.querySelector(selector);
        if (element instanceof HTMLInputElement || element instanceof HTMLSelectElement || element instanceof HTMLTextAreaElement) {
          return element.value.trim();
        }
        return "";
      };

      const getFormSummary = () => {
        const intent = getSelectedIntent();
        const areas = areaInputs
          .filter((input) => input instanceof HTMLInputElement && input.checked)
          .map((input) => input instanceof HTMLInputElement ? input.value : "")
          .filter(Boolean);

        const common = {
          intent,
          intentLabel: intentLabels[intent] || "Förfrågan",
          areas: areas.join(", ") || "Inte angivet",
          name: valueOf("#name"),
          company: valueOf("#company"),
          email: valueOf("#email"),
          phone: valueOf("#phone"),
          replyMethod: valueOf('input[name="replyMethod"]:checked')
        };

        if (intent === "project") {
          return {
            ...common,
            environment: valueOf("#project-environment"),
            stage: valueOf("#project-stage"),
            location: valueOf("#project-location"),
            timeline: valueOf("#project-timeline"),
            description: valueOf("#project-description")
          };
        }

        if (intent === "service") {
          return {
            ...common,
            location: valueOf("#service-location"),
            urgency: valueOf("#service-urgency"),
            system: valueOf("#service-system"),
            description: valueOf("#service-description")
          };
        }

        if (intent === "advice") {
          return {
            ...common,
            environment: valueOf("#advice-environment"),
            stage: valueOf("#advice-stage"),
            description: valueOf("#advice-description")
          };
        }

        return {
          ...common,
          description: valueOf("#other-description")
        };
      };

      const summaryRows = (data) => {
        const rows = [
          ["Ärende", data.intentLabel],
          ["Område", data.areas]
        ];

        if (data.environment) rows.push(["Miljö", data.environment]);
        if (data.stage) rows.push(["Projektläge", data.stage]);
        if (data.location) rows.push(["Plats", data.location]);
        if (data.timeline) rows.push(["Tidplan", data.timeline]);
        if (data.urgency) rows.push(["Prioritet", data.urgency]);
        if (data.system) rows.push(["Anläggning/system", data.system]);

        rows.push(
          ["Beskrivning", data.description || "Inte angivet"],
          ["Namn", data.name],
          ["Företag/organisation", data.company || "Inte angivet"],
          ["E-post", data.email || "Inte angivet"],
          ["Telefon", data.phone || "Inte angivet"],
          ["Önskad kontaktväg", data.replyMethod || "Telefon eller e-post"]
        );

        return rows;
      };

      const buildReview = () => {
        if (!(reviewList instanceof HTMLElement)) return;
        const data = getFormSummary();
        const rows = summaryRows(data);
        reviewList.replaceChildren();

        rows.forEach(([label, value]) => {
          const term = document.createElement("dt");
          const description = document.createElement("dd");
          term.textContent = label;
          description.textContent = value;
          reviewList.append(term, description);
        });

        lastSummary = createMailBody(data);
      };

      const createMailBody = (data) => {
        const rows = summaryRows(data);
        const details = rows.map(([label, value]) => `${label}: ${value}`).join("\n");
        return [
          "Hej AVAB,",
          "",
          "Jag vill gärna ha hjälp med följande:",
          "",
          details,
          "",
          "Jag lägger till eventuella ritningar, bilder eller andra bilagor i detta mejl.",
          "",
          "Vänliga hälsningar,",
          data.name
        ].join("\n");
      };

      const copySummary = async () => {
        if (!lastSummary) buildReview();
        if (!navigator.clipboard || !window.isSecureContext) return false;
        try {
          await navigator.clipboard.writeText(lastSummary);
          return true;
        } catch {
          return false;
        }
      };

      intentInputs.forEach((input) => {
        input.addEventListener("change", () => {
          intentError?.classList.remove("is-visible");
          setConditionalFields();
        });
      });

      areaInputs.forEach((input) => {
        input.addEventListener("change", () => {
          if (!(input instanceof HTMLInputElement)) return;
          const exclusive = input.hasAttribute("data-exclusive");

          if (input.checked && exclusive) {
            areaInputs.forEach((other) => {
              if (other !== input && other instanceof HTMLInputElement) other.checked = false;
            });
          } else if (input.checked) {
            const unsure = document.querySelector("#area-unsure");
            if (unsure instanceof HTMLInputElement) unsure.checked = false;
          }

          areaError?.classList.remove("is-visible");
        });
      });

      intentLinks.forEach((link) => {
        link.addEventListener("click", () => {
          const intent = link.getAttribute("data-contact-intent");
          const input = document.querySelector(`#intent-${intent}`);
          if (input instanceof HTMLInputElement) {
            input.checked = true;
            setConditionalFields();
            intentError?.classList.remove("is-visible");
          }
          setStep(1, false);
        });
      });

      stepButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const target = Number(button.getAttribute("data-step-target"));
          if (target <= highestReached) setStep(target);
        });
      });

      document.querySelectorAll("[data-next]").forEach((button) => {
        button.addEventListener("click", () => {
          if (!validateStep(currentStep, true)) return;
          setStep(currentStep + 1);
        });
      });

      document.querySelectorAll("[data-prev]").forEach((button) => {
        button.addEventListener("click", () => setStep(currentStep - 1));
      });

      copyButton?.addEventListener("click", async () => {
        const copied = await copySummary();
        if (formStatus instanceof HTMLElement) {
          formStatus.textContent = copied
            ? "Sammanfattningen är kopierad."
            : "Det gick inte att kopiera automatiskt. Markera texten i sammanfattningen och kopiera manuellt.";
        }
      });

      if (form instanceof HTMLFormElement) {
        form.addEventListener("submit", async (event) => {
          event.preventDefault();

          if (currentStep < 4) {
            if (validateStep(currentStep, true)) setStep(currentStep + 1);
            return;
          }

          for (let step = 1; step <= 3; step += 1) {
            if (!validateStep(step, false)) {
              setStep(step);
              validateStep(step, true);
              return;
            }
          }

          const data = getFormSummary();
          const body = createMailBody(data);
          const subjectBits = [data.intentLabel];
          if (data.company) subjectBits.push(data.company);
          else if (data.name) subjectBits.push(data.name);

          const subject = encodeURIComponent(subjectBits.join(" – "));
          const fullMailto = `mailto:info@avab.eu?subject=${subject}&body=${encodeURIComponent(body)}`;
          const copied = await copySummary();
          const mailtoIsLong = fullMailto.length > 1900;
          const mailto = mailtoIsLong && copied
            ? `mailto:info@avab.eu?subject=${subject}`
            : fullMailto;

          if (formStatus instanceof HTMLElement) {
            if (mailtoIsLong && copied) {
              formStatus.textContent = "Sammanfattningen är för lång för vissa e-postprogram och har därför kopierats. Klistra in den i mejlet som öppnas och lägg till eventuella bilagor.";
            } else {
              formStatus.textContent = copied
                ? "Ett färdigt mejl öppnas nu. Texten har också kopierats som reserv."
                : "Ett färdigt mejl öppnas nu. Kontrollera innehållet och lägg till eventuella bilagor innan ni skickar.";
            }
          }

          window.location.href = mailto;
        });
      }

      setConditionalFields();
      setStep(1, false);
    </script>
  </body>
</html>
