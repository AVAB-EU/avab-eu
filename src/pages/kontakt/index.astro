  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad ska jag skicka med när jag kontaktar AVAB?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Skicka gärna ritningar, planlösning, FFU eller kravtext och en kort beskrivning av miljön. Saknas underlag går det lika bra att ringa och beskriva projektet."
        }
      },
      {
        "@type": "Question",
        "name": "Arbetar AVAB i hela Sverige?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. AVAB utgår från Hammarö i Värmland och tar uppdrag i hela Sverige, från projektering till installation och driftsättning."
        }
      },
      {
        "@type": "Question",
        "name": "Kostar en första genomgång något?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nej. En första genomgång av ritningar, behov och förutsättningar är kostnadsfri och utan förpliktelser."
        }
      },
      {
        "@type": "Question",
        "name": "Kan AVAB enbart projektera, utan att installera?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. AVAB kan projektera och driftsätta medan elektriker installerar efter underlag. AVAB kan också ta hela leveransen från ritning till drift."
        }
      },
      {
        "@type": "Question",
        "name": "Jobbar AVAB med offentlig upphandling?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. AVAB tar fram underlag för FFU och arbetar med kommuner, upphandlare och byggbolag enligt AB 04 och ABT 06."
        }
      },
      {
        "@type": "Question",
        "name": "Vem vänder sig AVAB till?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Kommuner, skolor, byggbolag, elektriker, fastighetsägare och verksamheter som behöver ljud, bild eller säkerhet i publika miljöer."
        }
      }
    ]
  }
  </script>

