---
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import "../../styles/avab.css";

const pageTitle = "Kontakta AVAB | Projekt, offert, rådgivning och service";
const pageDescription =
  "Kontakta AVAB om professionellt ljud, bild, säkerhet, hörslinga, rastsignal, talat utrymningslarm, projektering eller service. Beskriv behovet steg för steg.";
const canonicalUrl = "https://www.avab.eu/kontakt/";
---

<!DOCTYPE html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="author" content="AVAB" />
    <meta name="theme-color" content="#282E29" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content="https://www.avab.eu/assets/Hanza%20konf%201200x900.webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="900" />
    <meta property="og:image:alt" content="Konferensrum med professionell AV-teknik från AVAB" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="sv_SE" />
    <meta property="og:site_name" content="AVAB" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content="https://www.avab.eu/assets/Hanza%20konf%201200x900.webp" />
    <meta name="twitter:image:alt" content="Konferensrum med professionell AV-teknik från AVAB" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "@id": "https://www.avab.eu/#organization",
        "name": "AVAB",
        "url": "https://www.avab.eu/",
        "image": "https://www.avab.eu/assets/Hanza%20konf%201200x900.webp",
        "telephone": "+46-54-8202080",
        "email": "info@avab.eu",
        "description": "AVAB hjälper företag, kommuner, skolor, fastighetsägare, elektriker och andra organisationer med projektering, installation och service av professionella system för ljud, bild, säkerhet och styrning.",
        "areaServed": { "@type": "Country", "name": "Sverige" },
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Skraggevägen 4",
          "postalCode": "663 41",
          "addressLocality": "Hammarö",
          "addressRegion": "Värmland",
          "addressCountry": "SE"
        },
        "openingHoursSpecification": [{
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "08:00",
          "closes": "17:00"
        }],
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "telephone": "+46-54-8202080",
          "email": "info@avab.eu",
          "availableLanguage": "Swedish",
          "areaServed": "SE"
        },
        "knowsAbout": [
          "AV-teknik",
          "Ljudsystem",
          "Konferensteknik",
          "Kameraövervakning",
          "Hörslinga",
          "Rastsignalsystem",
          "Talat utrymningslarm",
          "Taluppfattbarhet",
          "Projektering",
          "Systemintegration"
        ]
      }
    </script>

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "ContactPage",
        "@id": "https://www.avab.eu/kontakt/#webpage",
        "url": "https://www.avab.eu/kontakt/",
        "name": "Kontakta AVAB",
        "description": "Kontakta AVAB för rådgivning, projektering, installation och service inom professionellt ljud, bild, säkerhet och styrning.",
        "inLanguage": "sv-SE",
        "isPartOf": {
          "@type": "WebSite",
          "@id": "https://www.avab.eu/#website",
          "url": "https://www.avab.eu/",
          "name": "AVAB"
        },
        "about": { "@id": "https://www.avab.eu/#organization" },
        "datePublished": "2026-07-02",
        "dateModified": "2026-07-14",
        "speakable": {
          "@type": "SpeakableSpecification",
          "cssSelector": ["h1", ".hero .lead", ".contact-seo-summary", ".contact-faq"]
        }
      }
    </script>

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.avab.eu/" },
          { "@type": "ListItem", "position": 2, "name": "Kontakt", "item": "https://www.avab.eu/kontakt/" }
        ]
      }
    </script>

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Behöver vi veta exakt vilken teknisk lösning som krävs?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nej. Beskriv lokalen, problemet eller resultatet ni vill uppnå. AVAB hjälper er att identifiera rätt nästa steg."
            }
          },
          {
            "@type": "Question",
            "name": "Vad är bra att skicka med i en projektförfrågan?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Skicka gärna ritningar, planlösning, FFU, kravtext eller bilder. Saknas underlag går det bra att börja med en enkel beskrivning."
            }
          },
          {
            "@type": "Question",
            "name": "Kan AVAB enbart projektera utan att installera?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. AVAB kan projektera och ta fram underlag för kundens elektriker, eller ansvara för hela leveransen från projektering till driftsättning."
            }
          },
          {
            "@type": "Question",
            "name": "Arbetar AVAB i hela Sverige?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. AVAB utgår från Hammarö i Värmland och tar uppdrag i hela Sverige."
            }
          }
        ]
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link
      rel="preload"
      as="image"
      fetchpriority="high"
      href="/assets/Hanza konf 1200x900.webp"
      imagesrcset="/assets/Hanza konf 1200x900.webp 1200w"
      imagesizes="100vw"
    />

    <style>
      .contact-page {
        --contact-border: rgba(40, 46, 42, 0.16);
        --contact-border-strong: rgba(40, 46, 42, 0.28);
        --contact-focus: rgba(143, 192, 37, 0.24);
        --contact-danger: #a83224;
      }

      .contact-page .hero {
        min-height: 560px;
      }

      .contact-page .hero-inner {
        padding-bottom: 64px;
      }

      .contact-page .hero h1 {
        max-width: 19ch;
      }

      .hero-trust {
        display: flex;
        flex-wrap: wrap;
        gap: 12px 24px;
        margin-top: 26px;
        color: rgba(255, 255, 255, 0.94);
        font-size: 0.96rem;
        font-weight: 700;
      }

      .hero-trust span {
        display: inline-flex;
        align-items: center;
        gap: 10px;
      }

      .hero-trust span::before {
        content: "";
        flex: 0 0 auto;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--avab-green);
        box-shadow: 0 0 0 4px rgba(143, 192, 37, 0.16);
      }

      .quick-contact {
        padding: 28px 0 66px;
        background: var(--avab-light);
        border-bottom: 1px solid var(--avab-border);
      }

      .quick-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 20px;
      }

      .quick-card {
        min-width: 0;
        display: flex;
        flex-direction: column;
        min-height: 192px;
        padding: 28px;
        border: 1px solid var(--avab-border);
        border-radius: var(--avab-radius-sm);
        background: var(--avab-white);
        box-shadow: var(--avab-shadow-sm);
        transition: transform 0.24s ease, border-color 0.24s ease, box-shadow 0.24s ease;
      }

      .quick-card--primary {
        border-top: 5px solid var(--avab-green);
        padding-top: 24px;
      }

      .quick-card:hover,
      .quick-card:focus-within {
        transform: translateY(-4px);
        border-color: rgba(143, 192, 37, 0.65);
        box-shadow: 0 22px 44px rgba(40, 46, 42, 0.12);
      }

      .quick-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 46px;
        height: 46px;
        margin-bottom: 18px;
        border-radius: 14px;
        background: var(--avab-green-soft);
        color: var(--avab-green);
      }

      .quick-icon svg {
        width: 24px;
        height: 24px;
      }

      .quick-card h2 {
        margin-bottom: 10px;
        font-size: 1.3rem;
      }

      .quick-card p {
        margin-bottom: 20px;
        font-size: 0.96rem;
      }

      .quick-card a {
        margin-top: auto;
        font-weight: 800;
        color: var(--avab-dark);
      }

      .quick-card a::after {
        content: " →";
        color: var(--avab-green);
      }

      .quick-card a:hover,
      .quick-card a:focus-visible {
        color: var(--avab-green);
      }

      .contact-seo-summary {
        max-width: 840px;
        margin-bottom: 42px;
      }

      .contact-seo-summary p:last-child {
        margin-bottom: 0;
      }

      .contact-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(320px, 360px);
        gap: 30px;
        align-items: start;
      }

      .form-card {
        min-width: 0;
        overflow: hidden;
        overflow-anchor: none;
        border: 1px solid var(--avab-border);
        border-radius: var(--avab-radius);
        background: var(--avab-white);
        box-shadow: var(--avab-shadow-lg);
      }

      .form-card-header {
        padding: clamp(26px, 4vw, 40px) clamp(24px, 4vw, 44px) 24px;
        border-bottom: 1px solid var(--avab-border);
      }

      .form-card-header h2 {
        max-width: 18ch;
        margin-bottom: 10px;
        font-size: clamp(1.75rem, 3vw, 2.35rem);
      }

      .form-card-header p {
        max-width: 65ch;
        margin-bottom: 0;
        font-size: 1rem;
      }

      .progress-wrap {
        scroll-margin-top: calc(var(--avab-nav-height) + 16px);
        padding: 22px clamp(24px, 4vw, 44px) 20px;
        background: #fbfcfb;
        border-bottom: 1px solid var(--avab-border);
      }

      .progress-meta {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 12px;
        color: var(--avab-dark-muted);
        font-size: 0.82rem;
        font-weight: 800;
      }

      .progress-track {
        height: 7px;
        overflow: hidden;
        border-radius: 999px;
        background: var(--avab-grey);
      }

      .progress-fill {
        width: 25%;
        height: 100%;
        border-radius: inherit;
        background: var(--avab-green);
        transition: width 0.28s ease;
      }

      .step-nav {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin-top: 16px;
      }

      .step-button {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 0;
        border: 0;
        background: transparent;
        color: var(--avab-dark-muted);
        font: inherit;
        font-size: 0.78rem;
        font-weight: 800;
        text-align: left;
        cursor: pointer;
      }

      .step-button:disabled {
        cursor: default;
        opacity: 0.52;
      }

      .step-number {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border: 1px solid var(--contact-border);
        border-radius: 50%;
        background: var(--avab-white);
      }

      .step-button[aria-current="step"] {
        color: var(--avab-dark);
      }

      .step-button[aria-current="step"] .step-number,
      .step-button.is-complete .step-number {
        border-color: var(--avab-green);
        background: var(--avab-green);
        color: var(--avab-dark);
      }

      .multistep-form {
        min-width: 0;
      }

      .form-panel {
        padding: clamp(30px, 4vw, 44px);
        animation: contactFade 0.28s ease both;
      }

      .form-panel[hidden] {
        display: none;
      }

      @keyframes contactFade {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .panel-heading {
        margin-bottom: 28px;
      }

      .panel-kicker {
        display: block;
        margin-bottom: 8px;
        color: var(--avab-green);
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .panel-heading h3 {
        margin-bottom: 10px;
        font-size: clamp(1.5rem, 2.5vw, 2rem);
      }

      .panel-heading p {
        max-width: 64ch;
        margin-bottom: 0;
        font-size: 0.98rem;
      }

      .contact-page fieldset {
        min-width: 0;
        margin: 0;
        padding: 0;
        border: 0;
      }

      .contact-page legend,
      .group-title {
        display: block;
        width: 100%;
        margin-bottom: 14px;
        color: var(--avab-dark);
        font-size: 0.96rem;
        font-weight: 800;
      }

      .required-mark {
        color: var(--contact-danger);
      }

      .intent-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
      }

      .intent-option,
      .area-option,
      .pill-option {
        position: relative;
        min-width: 0;
      }

      .intent-option input,
      .area-option input,
      .pill-option input {
        position: absolute;
        width: 1px;
        height: 1px;
        opacity: 0;
        pointer-events: none;
      }

      .intent-option label {
        min-width: 0;
        display: flex;
        flex-direction: column;
        min-height: 154px;
        padding: 22px;
        border: 1px solid var(--contact-border);
        border-radius: 16px;
        background: var(--avab-white);
        cursor: pointer;
        transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
      }

      .intent-option label:hover {
        transform: translateY(-2px);
        border-color: rgba(143, 192, 37, 0.65);
      }

      .intent-option strong {
        display: block;
        margin-bottom: 7px;
        color: var(--avab-dark);
        font-size: 1.05rem;
      }

      .intent-option span {
        color: var(--avab-dark-muted);
        font-size: 0.88rem;
        line-height: 1.5;
      }

      .intent-option input:checked + label {
        border-color: var(--avab-green);
        background: var(--avab-green-soft);
        box-shadow: 0 0 0 3px rgba(143, 192, 37, 0.12);
      }

      .intent-option input:focus-visible + label,
      .area-option input:focus-visible + label,
      .pill-option input:focus-visible + label {
        outline: var(--avab-focus);
        outline-offset: 3px;
      }

      .form-block + .form-block {
        margin-top: 28px;
        padding-top: 28px;
        border-top: 1px solid var(--avab-border);
      }

      .area-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
      }

      .area-option label {
        min-width: 0;
        display: flex;
        align-items: center;
        min-height: 54px;
        padding: 12px 14px 12px 46px;
        border: 1px solid var(--contact-border);
        border-radius: 12px;
        background: var(--avab-white);
        color: var(--avab-dark);
        font-size: 0.9rem;
        font-weight: 700;
        line-height: 1.35;
        cursor: pointer;
        transition: border-color 0.2s ease, background 0.2s ease;
      }

      .area-option label::before {
        content: "";
        position: absolute;
        left: 16px;
        width: 18px;
        height: 18px;
        border: 2px solid rgba(40, 46, 42, 0.34);
        border-radius: 5px;
        background: #fff;
      }

      .area-option input:checked + label {
        border-color: var(--avab-green);
        background: var(--avab-green-soft);
      }

      .area-option input:checked + label::before {
        border-color: var(--avab-green);
        background: var(--avab-green);
        box-shadow: inset 0 0 0 4px #fff;
      }

      .field-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
      }

      .field--full {
        grid-column: 1 / -1;
      }

      .field {
        min-width: 0;
        display: grid;
        gap: 8px;
      }

      .field label {
        color: var(--avab-dark);
        font-size: 0.9rem;
        font-weight: 800;
      }

      .field-help,
      .group-help {
        margin: 0;
        color: var(--avab-dark-muted);
        font-size: 0.8rem;
        line-height: 1.5;
      }

      .multistep-form input:not([type="radio"]):not([type="checkbox"]),
      .multistep-form select,
      .multistep-form textarea {
        width: 100%;
        min-height: 54px;
        padding: 13px 15px;
        border: 1px solid var(--contact-border);
        border-radius: 12px;
        background: var(--avab-white);
        color: var(--avab-dark);
        font: inherit;
        font-size: 0.96rem;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
      }

      .multistep-form textarea {
        min-height: 150px;
        resize: vertical;
      }

      .multistep-form input:hover,
      .multistep-form select:hover,
      .multistep-form textarea:hover {
        border-color: var(--contact-border-strong);
      }

      .multistep-form input:focus,
      .multistep-form select:focus,
      .multistep-form textarea:focus {
        outline: none;
        border-color: var(--avab-green);
        box-shadow: 0 0 0 4px var(--contact-focus);
      }

      .multistep-form [aria-invalid="true"] {
        border-color: var(--contact-danger) !important;
      }

      .conditional-fields[hidden] {
        display: none;
      }

      .pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .pill-option label {
        display: inline-flex;
        align-items: center;
        min-height: 46px;
        padding: 0 18px;
        border: 1px solid var(--contact-border);
        border-radius: 999px;
        color: var(--avab-dark);
        font-size: 0.88rem;
        font-weight: 800;
        cursor: pointer;
      }

      .pill-option input:checked + label {
        border-color: var(--avab-green);
        background: var(--avab-green-soft);
      }

      .inline-error {
        display: none;
        margin: 10px 0 0;
        color: var(--contact-danger);
        font-size: 0.82rem;
        font-weight: 700;
      }

      .inline-error.is-visible {
        display: block;
      }

      .panel-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-top: 34px;
        padding-top: 24px;
        border-top: 1px solid var(--avab-border);
      }

      .panel-actions-group {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .button-outline {
        background: var(--avab-white);
        color: var(--avab-dark);
        border: 1px solid var(--contact-border);
        box-shadow: none;
      }

      .button-outline:hover {
        transform: translateY(-2px);
        border-color: var(--avab-green);
        color: var(--avab-dark);
        background: var(--avab-green-soft);
      }

      .button-link {
        min-height: 48px;
        padding: 0 8px;
        border: 0;
        background: transparent;
        color: var(--avab-dark-muted);
        font: inherit;
        font-weight: 800;
        cursor: pointer;
      }

      .button-link:hover {
        color: var(--avab-green);
      }

      .review-list {
        display: grid;
        grid-template-columns: minmax(130px, 0.34fr) minmax(0, 0.66fr);
        border: 1px solid var(--avab-border);
        border-radius: 14px;
        overflow: hidden;
      }

      .review-list dt,
      .review-list dd {
        min-width: 0;
        margin: 0;
        padding: 13px 16px;
        border-bottom: 1px solid var(--avab-border);
        overflow-wrap: anywhere;
      }

      .review-list dt {
        background: var(--avab-light);
        color: var(--avab-dark);
        font-size: 0.82rem;
        font-weight: 800;
      }

      .review-list dd {
        color: var(--avab-dark-muted);
        font-size: 0.9rem;
        white-space: pre-line;
      }

      .review-list dt:last-of-type,
      .review-list dd:last-of-type {
        border-bottom: 0;
      }

      .send-note {
        margin-top: 18px;
        padding: 16px 18px;
        border-left: 4px solid var(--avab-green);
        border-radius: 0 12px 12px 0;
        background: var(--avab-green-soft);
      }

      .send-note p {
        margin: 0;
        font-size: 0.86rem;
      }

      .form-status {
        min-height: 1.5em;
        margin: 14px 0 0;
        color: var(--avab-dark);
        font-size: 0.86rem;
        font-weight: 700;
      }

      .contact-sidebar {
        min-width: 0;
        display: grid;
        gap: 20px;
        position: sticky;
        top: calc(var(--avab-nav-height) + 24px);
      }

      .sidebar-card {
        min-width: 0;
        padding: 28px;
        border: 1px solid var(--avab-border);
        border-radius: var(--avab-radius-sm);
        background: var(--avab-white);
        box-shadow: var(--avab-shadow-sm);
      }

      .sidebar-card h2 {
        margin-bottom: 18px;
        font-size: 1.3rem;
      }

      .sidebar-card--dark {
        border: 0;
        border-left: 6px solid var(--avab-green);
        background: linear-gradient(145deg, var(--avab-dark), #1d221e);
        color: #fff;
        box-shadow: var(--avab-shadow-lg);
      }

      .sidebar-card--dark h2 {
        color: #fff;
      }

      .direct-contact-list,
      .next-step-list {
        display: grid;
        gap: 16px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .direct-contact-list > li > a,
      .direct-contact-list > li > .contact-row {
        min-width: 0;
        display: grid;
        grid-template-columns: 38px minmax(0, 1fr);
        gap: 12px;
        align-items: center;
      }

      .contact-row-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 11px;
        background: var(--avab-green-soft);
        color: var(--avab-green);
      }

      .contact-row-icon svg {
        width: 20px;
        height: 20px;
      }

      .contact-row-copy {
        min-width: 0;
        display: block;
      }

      .contact-row-copy small,
      .contact-row-copy strong {
        display: block;
        min-width: 0;
      }

      .contact-row-copy small {
        margin-bottom: 2px;
        color: var(--avab-dark-muted);
        font-size: 0.76rem;
        font-weight: 700;
      }

      .contact-row-copy strong {
        color: var(--avab-dark);
        font-size: 0.94rem;
        line-height: 1.35;
        overflow-wrap: anywhere;
      }

      .direct-contact-list a:hover strong,
      .direct-contact-list a:focus-visible strong {
        color: var(--avab-green);
      }

      .next-step-list {
        counter-reset: next-step;
      }

      .next-step-list li {
        position: relative;
        padding-left: 44px;
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.88rem;
        line-height: 1.5;
        counter-increment: next-step;
      }

      .next-step-list li::before {
        content: counter(next-step);
        position: absolute;
        left: 0;
        top: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: var(--avab-green);
        color: var(--avab-dark);
        font-size: 0.8rem;
        font-weight: 800;
      }

      .next-step-list strong {
        display: block;
        margin-bottom: 3px;
        color: #fff;
      }

      .attachment-note {
        margin-top: 20px;
        padding-top: 18px;
        border-top: 1px solid rgba(255, 255, 255, 0.14);
        color: rgba(255, 255, 255, 0.76);
        font-size: 0.82rem;
        line-height: 1.55;
      }

      .process-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 20px;
      }

      .process-card {
        padding: 26px;
        border: 1px solid var(--avab-border);
        border-radius: var(--avab-radius-sm);
        background: var(--avab-white);
        box-shadow: var(--avab-shadow-sm);
      }

      .process-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        margin-bottom: 16px;
        border-radius: 50%;
        background: var(--avab-green);
        color: var(--avab-dark);
        font-weight: 800;
      }

      .process-card h3 {
        font-size: 1.15rem;
      }

      .process-card p {
        margin-bottom: 0;
        font-size: 0.92rem;
      }

      .contact-faq {
        display: grid;
        grid-template-columns: minmax(250px, 0.72fr) minmax(0, 1.28fr);
        gap: 64px;
        align-items: start;
      }

      .faq-list {
        border-top: 1px solid var(--avab-border);
      }

      .faq-item {
        border-bottom: 1px solid var(--avab-border);
      }

      .faq-item summary {
        position: relative;
        padding: 22px 44px 22px 0;
        color: var(--avab-dark);
        font-size: 1rem;
        font-weight: 800;
        cursor: pointer;
        list-style: none;
      }

      .faq-item summary::-webkit-details-marker {
        display: none;
      }

      .faq-item summary::after {
        content: "+";
        position: absolute;
        right: 8px;
        top: 17px;
        color: var(--avab-green);
        font-size: 1.65rem;
        line-height: 1;
        transition: transform 0.2s ease;
      }

      .faq-item[open] summary::after {
        transform: rotate(45deg);
      }

      .faq-item p {
        max-width: 68ch;
        padding: 0 44px 24px 0;
        margin: 0;
        font-size: 0.94rem;
      }

      .final-contact-cta {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 32px;
        align-items: center;
        padding: clamp(32px, 5vw, 54px);
        border-radius: var(--avab-radius);
        background: linear-gradient(135deg, var(--avab-dark), #1f241f);
        box-shadow: var(--avab-shadow-lg);
      }

      .final-contact-cta h2,
      .final-contact-cta p {
        color: #fff;
      }

      .final-contact-cta p {
        margin-bottom: 0;
        color: rgba(255, 255, 255, 0.82);
      }

      .final-contact-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 12px;
      }

      @media (max-width: 1040px) {
        .contact-layout {
          grid-template-columns: 1fr;
        }

        .contact-sidebar {
          position: static;
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 820px) {
        .quick-grid,
        .process-grid,
        .contact-sidebar,
        .contact-faq,
        .final-contact-cta {
          grid-template-columns: 1fr;
        }

        .quick-card {
          min-height: auto;
        }

        .final-contact-actions {
          justify-content: flex-start;
        }
      }

      @media (max-width: 680px) {
        .contact-page .hero {
          min-height: 520px;
        }

        .contact-page .hero-inner {
          padding-top: 54px;
          padding-bottom: 48px;
        }

        .intent-grid,
        .area-grid,
        .field-grid {
          grid-template-columns: 1fr;
        }

        .field--full {
          grid-column: auto;
        }

        .step-label {
          display: none;
        }

        .step-button {
          justify-content: center;
        }

        .review-list {
          grid-template-columns: 1fr;
        }

        .review-list dt {
          padding-bottom: 4px;
          border-bottom: 0;
        }

        .review-list dd {
          padding-top: 4px;
        }

        .review-list dt:last-of-type {
          border-bottom: 0;
        }
      }

      @media (max-width: 520px) {
        .hero-actions .button,
        .panel-actions .button,
        .panel-actions-group,
        .panel-actions-group .button {
          width: 100%;
        }

        .panel-actions {
          align-items: stretch;
        }

        .form-card-header,
        .progress-wrap,
        .form-panel,
        .sidebar-card,
        .quick-card {
          padding-left: 22px;
          padding-right: 22px;
        }

        .progress-meta span:last-child {
          display: none;
        }
      }
    </style>
  </head>

  <body class="contact-page">
    <SiteHeader />

    <nav class="breadcrumbs" aria-label="Brödsmulor">
      <div class="avab-container">
        <ol>
          <li><a href="/">Start</a></li>
          <li><span aria-current="page">Kontakt</span></li>
        </ol>
      </div>
    </nav>

    <section class="hero" style="--hero-image:url('/assets/Hanza konf 1200x900.webp');">
      <div class="avab-container">
        <div class="hero-inner animate-in">
          <div class="eyebrow">Kontakt</div>
          <h1>Berätta vad ni vill lösa – vi hjälper er vidare</h1>
          <p class="lead">
            Ni behöver inte veta exakt vilken teknisk lösning som krävs. Beskriv projektet,
            miljön eller problemet med egna ord, så hjälper AVAB er att hitta rätt nästa steg.
          </p>

          <div class="hero-bottom">
            <div class="hero-actions">
              <a class="button button-primary" href="#kontaktformular" data-contact-intent="project">Starta en förfrågan</a>
              <a class="button button-secondary" href="tel:+46548202080">Ring 054-820 20 80</a>
              <a class="button button-quiet" href="#kontaktformular" data-contact-intent="service">Service och felanmälan</a>
            </div>

            <div class="hero-trust" aria-label="Trygghetsfaktorer">
              <span>Personlig teknisk rådgivning</span>
              <span>Från projektering till drift</span>
              <span>Uppdrag i hela Sverige</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <main id="main">
      <section class="quick-contact" aria-label="Välj kontaktväg">
        <div class="avab-container quick-grid">
          <article class="quick-card quick-card--primary clickable-card">
            <span class="quick-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <path d="M14 2v6h6" />
                <path d="M8 13h8M8 17h5" />
              </svg>
            </span>
            <h2>Nytt projekt eller offert</h2>
            <p>För nyinstallation, ombyggnad, projektering, uppgradering eller upphandling.</p>
            <a class="card-primary-link" href="#kontaktformular" data-contact-intent="project">Starta projektflödet</a>
          </article>

          <article class="quick-card clickable-card">
            <span class="quick-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a4 4 0 0 0-5-5L7.5 3.5l3 3 2.2-2.2a4 4 0 0 0 2 2Z" />
                <path d="m5 21 9.5-9.5" />
                <path d="M14 14.5 18.5 19a2.1 2.1 0 0 0 3-3L17 11.5" />
              </svg>
            </span>
            <h2>Service eller felsökning</h2>
            <p>Beskriv felet, anläggningen, platsen och hur verksamheten påverkas.</p>
            <a class="card-primary-link" href="#kontaktformular" data-contact-intent="service">Starta serviceflödet</a>
          </article>

          <article class="quick-card clickable-card">
            <span class="quick-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z" />
              </svg>
            </span>
            <h2>Prata direkt med oss</h2>
            <p>Snabbaste vägen när frågan är brådskande eller enklare att förklara muntligt.</p>
            <a class="card-primary-link" href="tel:+46548202080">Ring 054-820 20 80</a>
          </article>
        </div>
      </section>

      <section class="section section--light" id="kontaktformular">
        <div class="avab-container">
          <div class="contact-seo-summary">
            <div class="eyebrow">Förfrågan steg för steg</div>
            <h2>Ett kort flöde som anpassar sig efter ert ärende</h2>
            <p class="lead-dark">
              AVAB hjälper företag, kommuner, skolor, fastighetsägare, elektriker och andra
              organisationer med professionellt ljud, bild, säkerhet, styrning, projektering och service.
              Börja med det ni vet – formuläret visar bara de frågor som är relevanta.
            </p>
          </div>

          <div class="contact-layout">
            <div class="form-card">
              <header class="form-card-header">
                <h2>Vad kan vi hjälpa er med?</h2>
                <p>Fyra korta steg. Ni kan gå tillbaka och ändra innan sammanfattningen skapas.</p>
              </header>

              <div class="progress-wrap" aria-label="Formulärets framsteg">
                <div class="progress-meta">
                  <span id="progress-text">Steg 1 av 4</span>
                  <span>Tar vanligtvis 2–4 minuter</span>
                </div>
                <div class="progress-track" aria-hidden="true">
                  <div class="progress-fill" id="progress-fill"></div>
                </div>
                <div class="step-nav">
                  <button class="step-button" type="button" data-step-target="1" aria-current="step">
                    <span class="step-number">1</span><span class="step-label">Ärende</span>
                  </button>
                  <button class="step-button" type="button" data-step-target="2" disabled>
                    <span class="step-number">2</span><span class="step-label">Behov</span>
                  </button>
                  <button class="step-button" type="button" data-step-target="3" disabled>
                    <span class="step-number">3</span><span class="step-label">Kontakt</span>
                  </button>
                  <button class="step-button" type="button" data-step-target="4" disabled>
                    <span class="step-number">4</span><span class="step-label">Kontrollera</span>
                  </button>
                </div>
              </div>

              <form class="multistep-form" id="contact-form" novalidate>
                <section class="form-panel" data-step="1" aria-labelledby="step-1-title">
                  <div class="panel-heading">
                    <span class="panel-kicker">Steg 1</span>
                    <h3 id="step-1-title">Vad gäller er förfrågan?</h3>
                    <p>Välj det alternativ som ligger närmast. Det går att ändra senare.</p>
                  </div>

                  <fieldset>
                    <legend class="sr-only">Ärendetyp</legend>
                    <div class="intent-grid">
                      <div class="intent-option">
                        <input type="radio" id="intent-project" name="intent" value="project" />
                        <label for="intent-project">
                          <strong>Nytt projekt eller offert</strong>
                          <span>Nyinstallation, ombyggnad, uppgradering eller upphandling.</span>
                        </label>
                      </div>
                      <div class="intent-option">
                        <input type="radio" id="intent-service" name="intent" value="service" />
                        <label for="intent-service">
                          <strong>Service eller felsökning</strong>
                          <span>Något fungerar inte, behöver kontrolleras eller uppgraderas.</span>
                        </label>
                      </div>
                      <div class="intent-option">
                        <input type="radio" id="intent-advice" name="intent" value="advice" />
                        <label for="intent-advice">
                          <strong>Rådgivning eller projektering</strong>
                          <span>Ni är tidigt i processen och vill reda ut behov och förutsättningar.</span>
                        </label>
                      </div>
                      <div class="intent-option">
                        <input type="radio" id="intent-other" name="intent" value="other" />
                        <label for="intent-other">
                          <strong>Annat ärende</strong>
                          <span>Produktfråga, samarbete eller något som inte passar ovan.</span>
                        </label>
                      </div>
                    </div>
                    <p class="inline-error" id="intent-error" role="alert">Välj vad förfrågan gäller för att fortsätta.</p>
                  </fieldset>

                  <div class="panel-actions">
                    <span></span>
                    <button class="button button-primary" type="button" data-next>Fortsätt</button>
                  </div>
                </section>

                <section class="form-panel" data-step="2" aria-labelledby="step-2-title" hidden>
                  <div class="panel-heading">
                    <span class="panel-kicker">Steg 2</span>
                    <h3 id="step-2-title">Berätta lite om behovet</h3>
                    <p id="step-2-description">Frågorna anpassas efter den ärendetyp ni valde.</p>
                  </div>

                  <fieldset class="form-block">
                    <legend>Vilka områden gäller det?</legend>
                    <div class="area-grid">
                      <div class="area-option">
                        <input type="checkbox" id="area-audio" name="area" value="Ljudsystem och utrop" />
                        <label for="area-audio">Ljudsystem och utrop</label>
                      </div>
                      <div class="area-option">
                        <input type="checkbox" id="area-video" name="area" value="Bild och konferensteknik" />
                        <label for="area-video">Bild och konferensteknik</label>
                      </div>
                      <div class="area-option">
                        <input type="checkbox" id="area-camera" name="area" value="Kameraövervakning" />
                        <label for="area-camera">Kameraövervakning</label>
                      </div>
                      <div class="area-option">
                        <input type="checkbox" id="area-loop" name="area" value="Hörslinga och tillgänglighet" />
                        <label for="area-loop">Hörslinga och tillgänglighet</label>
                      </div>
                      <div class="area-option">
                        <input type="checkbox" id="area-school" name="area" value="Rastsignal och skolkommunikation" />
                        <label for="area-school">Rastsignal och skolkommunikation</label>
                      </div>
                      <div class="area-option">
                        <input type="checkbox" id="area-evac" name="area" value="Talat utrymningslarm" />
                        <label for="area-evac">Talat utrymningslarm</label>
                      </div>
                      <div class="area-option">
                        <input type="checkbox" id="area-control" name="area" value="Styrning och systemintegration" />
                        <label for="area-control">Styrning och systemintegration</label>
                      </div>
                      <div class="area-option">
                        <input type="checkbox" id="area-unsure" name="area" value="Jag vet inte ännu" data-exclusive />
                        <label for="area-unsure">Jag vet inte ännu</label>
                      </div>
                    </div>
                    <p class="inline-error" id="area-error" role="alert">Välj minst ett område eller ”Jag vet inte ännu”.</p>
                  </fieldset>

                  <div class="conditional-fields form-block" data-intent-fields="project" hidden>
                    <div class="field-grid">
                      <div class="field">
                        <label for="project-environment">Typ av miljö <span class="required-mark" aria-hidden="true">*</span></label>
                        <select id="project-environment" name="projectEnvironment" data-required>
                          <option value="">Välj miljö</option>
                          <option>Skola eller utbildningsmiljö</option>
                          <option>Sporthall, arena eller simhall</option>
                          <option>Kontor eller konferens</option>
                          <option>Hotell, restaurang eller butik</option>
                          <option>Industri, parkering eller utomhusmiljö</option>
                          <option>Vård, kyrka eller annan publik miljö</option>
                          <option>Annat eller inte bestämt</option>
                        </select>
                      </div>
                      <div class="field">
                        <label for="project-stage">Var befinner sig projektet?</label>
                        <select id="project-stage" name="projectStage">
                          <option value="">Inte bestämt ännu</option>
                          <option>Idé eller tidig planering</option>
                          <option>Projektering eller ritningsskede</option>
                          <option>Upphandling eller anbud</option>
                          <option>Byggnation eller installation pågår</option>
                          <option>Befintlig anläggning ska byggas om</option>
                        </select>
                      </div>
                      <div class="field">
                        <label for="project-location">Projektort eller anläggning</label>
                        <input id="project-location" name="projectLocation" type="text" autocomplete="address-level2" maxlength="160" />
                      </div>
                      <div class="field">
                        <label for="project-timeline">Önskad tidplan</label>
                        <select id="project-timeline" name="projectTimeline">
                          <option value="">Inte bestämt ännu</option>
                          <option>Så snart som möjligt</option>
                          <option>Inom 1–3 månader</option>
                          <option>Inom 3–6 månader</option>
                          <option>Inom 6–12 månader</option>
                          <option>Längre fram</option>
                        </select>
                      </div>
                      <div class="field field--full">
                        <label for="project-description">Vad vill ni uppnå? <span class="required-mark" aria-hidden="true">*</span></label>
                        <textarea id="project-description" name="projectDescription" maxlength="1800" data-required placeholder="Beskriv lokalen, hur lösningen ska användas och vad som behöver fungera bättre."></textarea>
                        <p class="field-help">Tekniska termer behövs inte. Det går bra att beskriva önskat resultat.</p>
                      </div>
                    </div>
                  </div>

                  <div class="conditional-fields form-block" data-intent-fields="service" hidden>
                    <div class="field-grid">
                      <div class="field">
                        <label for="service-location">Anläggning eller plats <span class="required-mark" aria-hidden="true">*</span></label>
                        <input id="service-location" name="serviceLocation" type="text" maxlength="180" data-required placeholder="Exempel: skola, sporthall eller adress" />
                      </div>
                      <div class="field">
                        <label for="service-urgency">Hur brådskande är det? <span class="required-mark" aria-hidden="true">*</span></label>
                        <select id="service-urgency" name="serviceUrgency" data-required>
                          <option value="">Välj prioritet</option>
                          <option>Akut driftstopp</option>
                          <option>Verksamheten är tydligt begränsad</option>
                          <option>Felet kan planeras in</option>
                          <option>Förebyggande kontroll eller uppgradering</option>
                        </select>
                      </div>
                      <div class="field field--full">
                        <label for="service-system">Vilken anläggning eller utrustning gäller det?</label>
                        <input id="service-system" name="serviceSystem" type="text" maxlength="250" placeholder="Fabrikat, systemtyp eller annan information ni känner till" />
                      </div>
                      <div class="field field--full">
                        <label for="service-description">Beskriv felet och hur verksamheten påverkas <span class="required-mark" aria-hidden="true">*</span></label>
                        <textarea id="service-description" name="serviceDescription" maxlength="1800" data-required placeholder="Vad händer, när började det och fungerar någon del av systemet fortfarande?"></textarea>
                      </div>
                    </div>
                  </div>

                  <div class="conditional-fields form-block" data-intent-fields="advice" hidden>
                    <div class="field-grid">
                      <div class="field">
                        <label for="advice-environment">Typ av miljö</label>
                        <input id="advice-environment" name="adviceEnvironment" type="text" maxlength="180" placeholder="Exempel: skola, kontor, sporthall eller butik" />
                      </div>
                      <div class="field">
                        <label for="advice-stage">När vill ni ta nästa beslut?</label>
                        <select id="advice-stage" name="adviceStage">
                          <option value="">Inte bestämt ännu</option>
                          <option>Inom några veckor</option>
                          <option>Inom 1–3 månader</option>
                          <option>Senare under året</option>
                          <option>Vi undersöker bara möjligheterna</option>
                        </select>
                      </div>
                      <div class="field field--full">
