      "logo": "https://www.avab.eu/logo.png",
      "image": "https://www.avab.eu/assets/sorby sporthall 1200x900.webp",
      "telephone": "+46-54-8202080",
      "email": "info@avab.eu",
      "sameAs": [
        "https://www.linkedin.com/company/avab",
        "https://www.facebook.com/avab"
      ],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Skraggevägen 4",
        "postalCode": "663 41",
        "addressLocality": "Hammarö",
        "addressRegion": "Värmland",
        "addressCountry": "SE"
      }
    },
    "areaServed": "Sverige",
    "serviceType": [
      "Ljudsystem gym",
      "Gymmusik och bakgrundsljud",
      "Ljud gruppträningssal",
      "Mikrofoner och headset gruppträning",
      "Digital signage gym",
      "Virtuella pass LED-vägg",
      "Ljusstyrning träningsanläggning",
      "Kameraövervakning gym"
    ],
    "description": "AVAB projekterar, installerar och driftsätter kompletta AV-lösningar för gym och träningsanläggningar: zonstyrt bakgrundsljud, gruppträningssalar med bas och mikrofoner, digital signage, LED-vägg och projektor för virtuella pass, ljusscenarier, styrning och kameraövervakning."
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad behöver ett gym för AV-teknik?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ofta bakgrundsljud i träningsytor, kraftigare ljud i gruppträningssalar, mikrofoner, enkel styrning, digital signage, bildlösningar för pass, ljuseffekter och kameraövervakning."
        }
      },
      {
        "@type": "Question",
        "name": "Kan musiken tidsstyras i ett gym?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Musiken kan starta när gymmet öppnar, ändra volym eller spellista över dagen och stängas av automatiskt när anläggningen stänger."
        }
      },
      {
        "@type": "Question",
        "name": "Vad är virtuella pass?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Virtuella pass är träningspass som spelas upp via skärm, LED-vägg eller projektor. Systemet startar automatiskt rätt video, ljudzon, volym och ljusscenario utan att en instruktör behöver vara på plats."
        }
      },
      {
        "@type": "Question",
        "name": "LED-vägg eller projektor till pass?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Det beror på lokalens ljus, budget, bildstorlek och användning. AVAB hjälper till att välja mellan LED-vägg, projektor, projektorduk eller stor skärm."
        }
      },
      {
        "@type": "Question",
        "name": "Kan en sporthall eller padelhall byggas om till gym?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Befintliga hallar kan få zonindelat ljud, infällda högtalare och bas, ny belysning och enkel styrning. AVAB har bland annat byggt om en sporthall till gym och lyft en äldre padelhall med pendlad belysning."
        }
      },
      {
        "@type": "Question",
        "name": "Kan AVAB installera kameraövervakning i gym?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, med fokus på trygghet vid obemannade tider: rätt kameraplacering, incidentuppföljning, behörighetsstyrning, rimlig lagringstid och tydlig skyltning mot medlemmar och personal."
        }
      },
      {
        "@type": "Question",
        "name": "Kan elektriker installera efter AVAB:s underlag?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. AVAB kan projektera och driftsätta, medan elektriker installerar efter underlag. AVAB kan också installera hela lösningen."
        }
      }
    ]
  }
  </script>

  <script type="application/ld+json">
