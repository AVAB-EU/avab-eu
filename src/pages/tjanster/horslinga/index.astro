  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": "https://www.avab.eu/tjanster/horslinga/#faq",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad är en hörslinga?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En hörslinga är ett system som skickar ljud trådlöst till hörapparater och cochleaimplantat med telespole. Ljudet överförs via ett magnetfält från en kabel eller folie som installeras i lokalen."
        }
      },
      {
        "@type": "Question",
        "name": "Vad är skillnaden mellan hörslinga och teleslinga?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Hörslinga, teleslinga, induktionsslinga och induktiv hörslinga är vanliga ord för samma grundteknik: ljud skickas via magnetfält till en mottagares telespole eller T-läge."
        }
      },
      {
        "@type": "Question",
        "name": "Vad är skillnaden mellan PLS och SLS?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "PLS är en enklare perimeterslinga som ofta passar mindre rum. SLS är en mer avancerad lösning för större eller mer krävande lokaler där man behöver jämnare täckning och bättre kontroll på läckage."
        }
      },
      {
        "@type": "Question",
        "name": "Läcker en hörslinga utanför rummet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, magnetfältet från en hörslinga kan sprida sig utanför rummet. Med SLS och rätt projektering kan läckaget begränsas betydligt bättre än med en enkel perimeterslinga."
        }
      },
      {
        "@type": "Question",
        "name": "Vad är Auracast?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Auracast är en Bluetooth LE Audio-baserad teknik som kan sända ljud trådlöst till många kompatibla mottagare samtidigt, till exempel vissa moderna hörapparater, hörlurar och andra enheter."
        }
      },
      {
        "@type": "Question",
        "name": "Kan en elektriker installera hörslingan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. AVAB kan projektera slingan, leverera ritningar och materialunderlag och stötta den lokala elektrikern. Systemval, injustering, mätning och dokumentation bör utföras av en aktör med erfarenhet av hörslingor."
        }
      },
      {
        "@type": "Question",
        "name": "När behöver AVAB komma in i projektet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Helst innan golv, kabelvägar, rackplats och upphandlingskrav är låsta. En golvförlagd slinga behöver projekteras och samordnas tidigt."
        }
      }
    ]
  }
  </script>

