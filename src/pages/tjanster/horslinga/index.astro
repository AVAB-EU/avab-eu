            <a class="button button-primary" href="/kontakt/">Boka genomgång</a>
            <a class="button button-secondary" href="#arbetssatt">Se arbetssätt</a>
            <a class="button button-quiet" href="tel:+46548202080">Ring 054-8202080</a>
          </div>
        </div>
      </div>
    </div>
  </section>

