  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad är skillnaden mellan lågohm och 100V?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Lågohm ger hög ljudkvalitet och tryck och passar när färre högtalare ska prestera mycket. 100V passar när många högtalare ska täcka stora ytor med jämnt ljud, till exempel korridorer, butiker och skolor."
        }
      },
      {
        "@type": "Question",
        "name": "Kan ett ljudsystem byggas i zoner?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Med DSP och rätt förstärkare kan olika ytor få olika ljudkällor, volymer och scheman, och styras enkelt av personalen."
        }
      },
      {
        "@type": "Question",
        "name": "Vad är taluppfattbarhet och STI?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Taluppfattbarhet beskriver hur väl tal uppfattas i en lokal. STI är måttet som används för att mäta det. Högtalarplacering, riktning och akustik avgör resultatet."
        }
      },
      {
        "@type": "Question",
        "name": "Behövs subbas i ett ljudsystem?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Det beror på användningen. För musik, event, gruppträning och klubbmiljö gör subbas stor skillnad. För rena talsystem är det sällan nödvändigt."
        }
      },
      {
        "@type": "Question",
        "name": "Klarar högtalare fukt och kyla?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, om rätt högtalare väljs. Simhallar, ishallar och utomhusmiljöer kräver material och IP-klassning som tål miljön."
        }
      },
      {
        "@type": "Question",
        "name": "Kan ljudsystemet användas för utrymningslarm?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Endast om det projekteras och verifieras för det. Talat utrymningslarm är ett säkerhetssystem med egna krav på övervakning, reservkraft och prioritet."
        }
      },
      {
        "@type": "Question",
        "name": "Kan elektriker installera efter AVAB:s underlag?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. AVAB kan projektera, mäta och driftsätta, medan elektriker installerar efter underlag. AVAB kan också installera hela lösningen."
        }
      }
    ]
  }
  </script>

