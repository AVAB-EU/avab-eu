  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad är AV-projektering?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AV-projektering är planering av ljud, bild, ljus, styrning, hörslinga, mikrofoner, skärmar, projektorer, nätverk, kablage och tekniska funktioner innan installation."
        }
      },
      {
        "@type": "Question",
        "name": "När ska AVAB komma in i projektet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Helst innan kabelvägar, undertak, golv, teknikrum och FFU är låsta. Ju tidigare AV-tekniken samordnas med el, IT, bygg, brand och verksamhet, desto färre kompromisser behövs senare."
        }
      },
      {
        "@type": "Question",
        "name": "Kan AVAB hjälpa elektriker med underlag?",
